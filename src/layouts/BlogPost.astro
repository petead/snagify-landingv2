---
import type { CollectionEntry } from 'astro:content';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import CrispChat from '../components/CrispChat.astro';
import Clarity from '../components/Clarity.astro';
import GoogleAnalytics from '../components/GoogleAnalytics.astro';
import MetaPixel from '../components/MetaPixel.astro';
import { formatBlogDate, readingTimeMinutes } from '../lib/blog';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, pubDate, updatedDate, author, faq, tags } = post.data;
const slug = post.slug;
const canonical = `https://snagify.net/blog/${slug}`;
const pageTitle = `${title} | Snagify`;
const minutes = readingTimeMinutes(post.body);
const datePublished = pubDate.toISOString();
const dateModified = (updatedDate ?? pubDate).toISOString();
const faqItems = faq ?? [];

const articleLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  datePublished,
  dateModified,
  author: {
    '@type': 'Person',
    name: author,
  },
  publisher: {
    '@type': 'Organization',
    name: 'Snagify',
    logo: {
      '@type': 'ImageObject',
      url: 'https://app.snagify.net/icon-512x512.png',
    },
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': canonical,
  },
};

const faqLd =
  faqItems.length > 0
    ? {
        '@context': 'https://schema.org',
        '@type': 'FAQPage',
        mainEntity: faqItems.map((item) => ({
          '@type': 'Question',
          name: item.question,
          acceptedAnswer: {
            '@type': 'Answer',
            text: item.answer,
          },
        })),
      }
    : null;
---
<!DOCTYPE html>
<html lang="en">
<head>
<GoogleAnalytics />
<MetaPixel />
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>{pageTitle}</title>
<meta name="description" content={description}>
<link rel="canonical" href={canonical}>

<meta property="og:type" content="article">
<meta property="og:title" content={pageTitle}>
<meta property="og:description" content={description}>
<meta property="og:url" content={canonical}>
<meta property="og:site_name" content="Snagify">
<meta property="og:image" content="https://snagify.net/og-image.jpg">
<meta property="article:published_time" content={datePublished}>
{updatedDate && <meta property="article:modified_time" content={dateModified} />}
{tags.map((tag) => <meta property="article:tag" content={tag} />)}

<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content={pageTitle}>
<meta name="twitter:description" content={description}>
<meta name="twitter:image" content="https://snagify.net/og-image.jpg">

<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
<link rel="icon" href="/favicon.ico">

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Poppins:ital,wght@0,400;0,500;0,700;0,800;1,700;1,800&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300;1,9..40,400&display=swap" rel="stylesheet">

<script type="application/ld+json" set:html={JSON.stringify(articleLd)} />
{faqLd && <script type="application/ld+json" set:html={JSON.stringify(faqLd)} />}

<style>
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
:root {
  --cream: #F3F1EB;
  --cream-2: #EAE8E0;
  --white: #FCFCFC;
  --ink: #0E0E10;
  --ink-60: rgba(14,14,16,0.6);
  --ink-25: rgba(14,14,16,0.1);
  --purple: #9A88FD;
  --purple-bg: #EDE9FE;
}
html { scroll-behavior: smooth; }
body {
  font-family: 'DM Sans', sans-serif;
  background: var(--cream);
  color: var(--ink);
  -webkit-font-smoothing: antialiased;
}
a, button { cursor: pointer; }

.blog-wrap {
  max-width: 720px;
  margin: 0 auto;
  padding: 72px 24px 96px;
}
.blog-kicker {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--ink-60);
  margin-bottom: 18px;
  text-decoration: none;
}
.blog-kicker:hover { color: var(--ink); }
.blog-title {
  font-family: 'Poppins', sans-serif;
  font-weight: 800;
  font-size: clamp(32px, 5vw, 46px);
  letter-spacing: -1.5px;
  line-height: 1.1;
  margin-bottom: 18px;
}
.blog-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 8px 16px;
  font-size: 14px;
  color: var(--ink-60);
  margin-bottom: 40px;
  padding-bottom: 28px;
  border-bottom: 1px solid var(--ink-25);
}
.blog-prose {
  max-width: 70ch;
  font-size: 17px;
  line-height: 1.75;
  color: var(--ink);
}
.blog-prose :global(h2) {
  font-family: 'Poppins', sans-serif;
  font-weight: 700;
  font-size: 1.45rem;
  letter-spacing: -0.5px;
  margin: 2.2em 0 0.7em;
  line-height: 1.25;
}
.blog-prose :global(h3) {
  font-family: 'Poppins', sans-serif;
  font-weight: 700;
  font-size: 1.15rem;
  margin: 1.8em 0 0.55em;
}
.blog-prose :global(p) { margin: 0 0 1.15em; color: var(--ink-60); }
.blog-prose :global(p:last-child) { margin-bottom: 0; }
.blog-prose :global(ul),
.blog-prose :global(ol) {
  margin: 0 0 1.15em 1.25em;
  color: var(--ink-60);
}
.blog-prose :global(li) { margin-bottom: 0.4em; }
.blog-prose :global(a) { color: var(--ink); text-decoration: underline; text-underline-offset: 3px; }
.blog-prose :global(a:hover) { color: var(--purple); }
.blog-prose :global(strong) { color: var(--ink); font-weight: 600; }

.blog-faq {
  margin-top: 56px;
  padding-top: 36px;
  border-top: 1px solid var(--ink-25);
}
.blog-faq h2 {
  font-family: 'Poppins', sans-serif;
  font-weight: 700;
  font-size: 1.45rem;
  letter-spacing: -0.5px;
  margin-bottom: 20px;
}
.blog-faq-list {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 12px;
}
.blog-faq-item {
  background: var(--white);
  border: 1px solid var(--ink-25);
  border-radius: 16px;
  padding: 18px 20px;
}
.blog-faq-item summary {
  font-family: 'Poppins', sans-serif;
  font-weight: 700;
  font-size: 16px;
  cursor: pointer;
  list-style: none;
}
.blog-faq-item summary::-webkit-details-marker { display: none; }
.blog-faq-item p {
  margin-top: 12px;
  font-size: 15px;
  line-height: 1.65;
  color: var(--ink-60);
}

.blog-cta {
  margin-top: 56px;
  padding: 32px 28px;
  background: var(--purple-bg);
  border: 1px solid rgba(154,136,253,0.3);
  border-radius: 22px;
}
.blog-cta h2 {
  font-family: 'Poppins', sans-serif;
  font-weight: 800;
  font-size: 1.35rem;
  letter-spacing: -0.5px;
  margin-bottom: 8px;
}
.blog-cta p {
  font-size: 15px;
  color: var(--ink-60);
  margin-bottom: 20px;
  line-height: 1.55;
}
.blog-cta-btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 14px 22px;
  border-radius: 999px;
  background: var(--ink);
  color: var(--white);
  font-family: 'Poppins', sans-serif;
  font-weight: 700;
  font-size: 14px;
  text-decoration: none;
  transition: transform .2s ease, box-shadow .2s ease;
}
.blog-cta-btn:hover {
  transform: translateY(-2px);
  box-shadow: 0 10px 24px rgba(14,14,16,.18);
}

@media (max-width: 640px) {
  .blog-wrap { padding: 48px 20px 72px; }
}
</style>
<CrispChat />
<Clarity />
</head>
<body>

<SiteHeader />

<article class="blog-wrap">
  <a class="blog-kicker" href="/blog">← Blog</a>
  <h1 class="blog-title">{title}</h1>
  <div class="blog-meta">
    <time datetime={datePublished}>{formatBlogDate(pubDate)}</time>
    <span aria-hidden="true">·</span>
    <span>{minutes} min read</span>
    <span aria-hidden="true">·</span>
    <span>{author}</span>
  </div>

  <div class="blog-prose">
    <slot />
  </div>

  {faqItems.length > 0 && (
    <section class="blog-faq" aria-labelledby="blog-faq-heading">
      <h2 id="blog-faq-heading">Frequently asked questions</h2>
      <ul class="blog-faq-list">
        {faqItems.map((item) => (
          <li>
            <details class="blog-faq-item">
              <summary>{item.question}</summary>
              <p>{item.answer}</p>
            </details>
          </li>
        ))}
      </ul>
    </section>
  )}

  <aside class="blog-cta" aria-label="Call to action">
    <h2>Protect your deposit from day one</h2>
    <p>Free check-in report, 20 minutes, court-ready PDF.</p>
    <a class="blog-cta-btn" href="https://app.snagify.net/signup">Start free →</a>
  </aside>
</article>

<SiteFooter />

</body>
</html>
