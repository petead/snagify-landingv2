---
const GA_ID = 'G-CR2PTLC7YS';
const ADS_ID = (import.meta.env.PUBLIC_GOOGLE_ADS_ID as string | undefined)?.trim() || '';
---
<!-- Google tag (gtag.js) — GA4 + optional Google Ads destination -->
<script async src={`https://www.googletagmanager.com/gtag/js?id=${GA_ID}`} is:inline></script>
<script is:inline define:vars={{ GA_ID, ADS_ID }}>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());

  gtag('config', GA_ID);
  if (ADS_ID) {
    gtag('config', ADS_ID, { allow_enhanced_conversions: true });
  }
</script>
