---
interface Props {
  variant: 'pro' | 'individual';
}

const { variant } = Astro.props;
---

{variant === 'pro' ? (
  <div class="faqx">
    <p class="faqx-lede">One shared wallet for the whole team.
    <strong>The property sets the price,</strong> not the report type.</p>

    <div class="faqx-calc" id="faqxCalcPro">
      <div class="faqx-controls">
        <div class="faqx-segment" data-role="type">
          <button type="button" class="on" data-base="1">Apartment<small>up to 2 bedrooms</small></button>
          <button type="button" data-base="2">Villa / 3BR+<small>3 bedrooms or more</small></button>
        </div>
        <div class="faqx-furn" data-role="furn">
          <span class="faqx-tlabel">Furnished with inventory</span>
          <span class="faqx-switch"></span>
        </div>
      </div>
      <div class="faqx-result">
        <span class="faqx-rlabel">Check-in or check-out</span>
        <div class="faqx-total">
          <span class="faqx-num" data-role="num">1</span>
          <div class="faqx-unit" data-role="unit">credit each</div>
        </div>
      </div>
    </div>

    <p class="faqx-fine">Bedrooms are counted from the rooms selected in the app.
    Credits refresh monthly and roll over while you're subscribed.</p>

    <button type="button" class="faqx-cta" data-faq-switch="individual">You're an individual? →</button>
  </div>
) : (
  <div class="faqx">
    <p class="faqx-lede"><strong>Check-in is always free.</strong> You only pay to
    lock the check-out report, the one that protects your deposit.</p>

    <div class="faqx-calc" id="faqxCalcIndiv">
      <div class="faqx-controls">
        <div class="faqx-segment" data-role="type">
          <button type="button" class="on" data-base="2">Apartment<small>up to 2 bedrooms</small></button>
          <button type="button" data-base="4">Villa / 3BR+<small>3 bedrooms or more</small></button>
        </div>
        <div class="faqx-furn" data-role="furn">
          <span class="faqx-tlabel">Furnished with inventory</span>
          <span class="faqx-switch"></span>
        </div>
      </div>
      <div class="faqx-free"><span class="faqx-fdot"></span>Check-in <small>· Free, always</small></div>
      <div class="faqx-result">
        <span class="faqx-rlabel">Check-out</span>
        <div class="faqx-total">
          <span class="faqx-num" data-role="num">2</span>
          <div class="faqx-unit" data-role="unit">credits</div>
        </div>
      </div>
    </div>

    <p class="faqx-fine"><b>10× cheaper</b> than a traditional inspection company
    (AED 1,200+). Credits never expire.</p>

    <button type="button" class="faqx-cta" data-faq-switch="pro">You're a pro? →</button>
  </div>
)}

<style is:global>
.faqx{--fq-purple:#9A88FD;--fq-purple-soft:#EFEBFF;--fq-gold:#F5C24A;
--fq-gold-soft:#FBF3DF;--fq-ink:#0A0810;--fq-ink60:#5B5566;--fq-ink40:#8B86A3;
--fq-cream:#F8F7F4;--fq-line:#E7E4DC}
.faqx-lede{color:var(--fq-ink60);font-size:1.02rem;line-height:1.5;max-width:44ch;margin:0 0 24px}
.faqx-lede strong{color:var(--fq-ink)}
.faqx-calc{border:1px solid var(--fq-line);border-radius:18px;overflow:hidden;margin-bottom:18px}
.faqx-controls{padding:20px;display:flex;flex-direction:column;gap:12px;background:var(--fq-cream)}
.faqx-segment{display:flex;background:#EDEBE4;border-radius:12px;padding:4px;gap:4px}
.faqx-segment button{flex:1;border:none;background:transparent;cursor:pointer;
font-weight:700;font-size:.92rem;color:var(--fq-ink60);padding:12px 8px;
border-radius:9px;transition:all .18s ease;line-height:1.25;font-family:inherit}
.faqx-segment button small{display:block;font-weight:500;font-size:.72rem;color:var(--fq-ink40);margin-top:2px}
.faqx-segment button.on{background:var(--fq-ink);color:#fff}
.faqx-segment button.on small{color:rgba(255,255,255,.6)}
.faqx-furn{display:flex;align-items:center;justify-content:space-between;
background:#fff;border:1px solid var(--fq-line);border-radius:12px;
padding:13px 16px;cursor:pointer;user-select:none;transition:border-color .18s ease}
.faqx-furn.on{border-color:var(--fq-gold);background:var(--fq-gold-soft)}
.faqx-tlabel{font-weight:700;font-size:.92rem}
.faqx-switch{width:44px;height:26px;border-radius:100px;background:#DDD9CF;
position:relative;flex-shrink:0;transition:background .18s ease}
.faqx-switch::after{content:"";position:absolute;top:3px;left:3px;width:20px;
height:20px;border-radius:50%;background:#fff;transition:transform .18s ease;
box-shadow:0 1px 3px rgba(0,0,0,.2)}
.faqx-furn.on .faqx-switch{background:var(--fq-gold)}
.faqx-furn.on .faqx-switch::after{transform:translateX(18px)}
.faqx-free{display:flex;align-items:center;gap:10px;padding:13px 20px;
background:var(--fq-purple-soft);font-size:.92rem;font-weight:700;color:#5B48D8;
border-bottom:1px solid var(--fq-line)}
.faqx-free small{font-weight:500;color:#7A6CE0}
.faqx-fdot{width:8px;height:8px;border-radius:50%;background:var(--fq-purple)}
.faqx-result{display:flex;align-items:baseline;justify-content:space-between;gap:16px;padding:22px 20px;background:#fff}
.faqx-rlabel{font-size:.95rem;font-weight:500;color:var(--fq-ink60)}
.faqx-total{text-align:right}
.faqx-num{font-family:Poppins,sans-serif;font-weight:800;font-size:2.6rem;line-height:1;display:inline-block;transition:transform .15s ease}
.faqx-num.pop{transform:scale(1.12)}
.faqx-unit{font-size:.78rem;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--fq-ink40);margin-top:2px}
.faqx-fine{font-size:.84rem;color:var(--fq-ink40);line-height:1.55;margin:0 0 24px;max-width:48ch}
.faqx-fine b{color:var(--fq-ink60)}
.faqx-cta{display:inline-flex;align-items:center;gap:8px;font-weight:700;
font-size:.92rem;color:var(--fq-ink);background:transparent;cursor:pointer;
padding:12px 20px;border:1.5px solid var(--fq-ink);border-radius:100px;
transition:all .18s ease;font-family:inherit}
.faqx-cta:hover{background:var(--fq-ink);color:#fff;gap:12px}
</style>
