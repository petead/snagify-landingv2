---
const { currentLocale = 'en' } = Astro.props;

const languages = [
  { code: 'en', label: 'English', native: 'English', dir: 'ltr' },
  { code: 'ar', label: 'Arabic', native: 'العربية', dir: 'rtl' },
  { code: 'ru', label: 'Russian', native: 'Русский', dir: 'ltr' },
  { code: 'hi', label: 'Hindi', native: 'हिन्दी', dir: 'ltr' }
];

const arabicPaths = [
  '/', '/for/landlords', '/for/tenants', '/for/property-managers',
  '/for/real-estate-agencies', '/for/holiday-homes', '/for/property-investors',
  '/for/expats', '/inspections', '/inspections/dubai-marina',
  '/inspections/downtown-dubai', '/inspections/business-bay',
  '/inspections/jvc', '/inspections/palm-jumeirah',
  '/check-in-inspection-dubai', '/check-out-inspection-dubai',
  '/snagging-inspection-dubai'
];

const russianPaths = [...arabicPaths];
const hindiPaths = [...arabicPaths];

const current = languages.find(l => l.code === currentLocale) || languages[0];
---

<div
  class="lang-switcher"
  data-arabic-paths={JSON.stringify(arabicPaths)}
  data-russian-paths={JSON.stringify(russianPaths)}
  data-hindi-paths={JSON.stringify(hindiPaths)}
>
  <button
    class="lang-switcher-button"
    type="button"
    aria-label="Select language"
    aria-expanded="false"
    aria-haspopup="listbox"
  >
    <span class="lang-switcher-current">{current.code.toUpperCase()}</span>
    <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="6 9 12 15 18 9"/></svg>
  </button>
  <ul class="lang-switcher-menu" role="listbox">
    {languages.map(lang => (
      <li role="presentation">
        <a
          href="#"
          role="option"
          aria-selected={lang.code === currentLocale ? 'true' : 'false'}
          class:list={['lang-switcher-item', { 'is-current': lang.code === currentLocale }]}
          lang={lang.code}
          data-locale={lang.code}
        >
          <span class="lang-switcher-code">{lang.code.toUpperCase()}</span>
          <span class="lang-switcher-native">{lang.native}</span>
          {lang.code === currentLocale && (
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>
          )}
        </a>
      </li>
    ))}
  </ul>
</div>

<style>
.lang-switcher { position: relative; display: inline-block; }
.lang-switcher-button {
  display: inline-flex; align-items: center; gap: 6px;
  padding: 7px 12px;
  background: rgba(14,14,16,0.04);
  border: 1px solid rgba(14,14,16,0.08);
  border-radius: 999px;
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px; font-weight: 600;
  color: rgba(14,14,16,0.7);
  cursor: pointer;
  transition: background 0.2s, border-color 0.2s;
}
.lang-switcher-button:hover {
  background: rgba(14,14,16,0.08);
  border-color: rgba(14,14,16,0.15);
  color: #0E0E10;
}
.lang-switcher-button[aria-expanded="true"] {
  background: rgba(14,14,16,0.08);
  color: #0E0E10;
}
.lang-switcher-button[aria-expanded="true"] svg { transform: rotate(180deg); }
.lang-switcher-button svg { transition: transform 0.2s; }

.lang-switcher-menu {
  position: absolute; top: calc(100% + 6px); right: 0;
  list-style: none; padding: 6px; margin: 0;
  background: #FCFCFC;
  direction: ltr;
  text-align: left;
  border: 1px solid rgba(14,14,16,0.08);
  border-radius: 12px;
  box-shadow: 0 12px 32px rgba(14,14,16,0.12);
  min-width: 160px;
  opacity: 0; visibility: hidden;
  transform: translateY(-4px);
  transition: opacity 0.2s, transform 0.2s, visibility 0.2s;
  z-index: 110;
}
.lang-switcher-menu.is-open {
  opacity: 1; visibility: visible; transform: translateY(0);
}
.lang-switcher-item {
  display: flex; align-items: center; gap: 10px;
  padding: 8px 12px; border-radius: 8px;
  direction: ltr;
  text-align: left;
  font-family: 'DM Sans', system-ui, sans-serif;
  font-size: 13px; color: rgba(14,14,16,0.7);
  text-decoration: none;
  transition: background 0.15s, color 0.15s;
  cursor: pointer;
}
.lang-switcher-item:hover { background: rgba(154,136,253,0.08); color: #0E0E10; }
.lang-switcher-item.is-current { color: #9A88FD; font-weight: 600; }
.lang-switcher-item.is-current svg { margin-left: auto; }
.lang-switcher-code {
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px; font-weight: 700;
  color: rgba(14,14,16,0.5);
  width: 24px;
}
.lang-switcher-item.is-current .lang-switcher-code { color: #9A88FD; }
.lang-switcher-native { flex: 1; }

@media (max-width: 768px) {
  .lang-switcher-button { padding: 6px 10px; font-size: 10px; }
  .lang-switcher-menu { right: -4px; min-width: 140px; }
}
</style>

<script>
(function initLangSwitchers() {
  const switchers = document.querySelectorAll('.lang-switcher');

  switchers.forEach(switcher => {
    if (switcher.dataset.langInit === 'true') return;
    switcher.dataset.langInit = 'true';

    const button = switcher.querySelector('.lang-switcher-button');
    const menu = switcher.querySelector('.lang-switcher-menu');
    const items = switcher.querySelectorAll('.lang-switcher-item');

    if (!button || !menu) return;

    let arabicPaths, russianPaths, hindiPaths;
    try {
      arabicPaths = new Set(JSON.parse(switcher.dataset.arabicPaths || '[]'));
      russianPaths = new Set(JSON.parse(switcher.dataset.russianPaths || '[]'));
      hindiPaths = new Set(JSON.parse(switcher.dataset.hindiPaths || '[]'));
    } catch (e) {
      arabicPaths = new Set(['/']);
      russianPaths = new Set(['/']);
      hindiPaths = new Set(['/']);
    }

    function getCurrentLocale() {
      const path = window.location.pathname;
      if (path.startsWith('/ar/') || path === '/ar') return 'ar';
      if (path.startsWith('/ru/') || path === '/ru') return 'ru';
      if (path.startsWith('/hi/') || path === '/hi') return 'hi';
      return 'en';
    }

    function stripLocalePrefix(path) {
      const cleaned = path.replace(/^\/(ar|ru|hi|en)(?=\/|$)/, '');
      return cleaned || '/';
    }

    function getLocalizedPath(targetLocale) {
      const path = window.location.pathname;
      const cleanPath = stripLocalePrefix(path);

      if (targetLocale === 'en') {
        return cleanPath || '/';
      }

      const targetPaths = targetLocale === 'ar' ? arabicPaths
        : targetLocale === 'ru' ? russianPaths
        : targetLocale === 'hi' ? hindiPaths
        : null;

      if (!targetPaths) return cleanPath || '/';

      if (targetPaths.has(cleanPath)) {
        return cleanPath === '/' ? `/${targetLocale}/` : `/${targetLocale}${cleanPath}`;
      }
      return `/${targetLocale}/`;
    }

    button.addEventListener('click', (e) => {
      e.stopPropagation();
      const willOpen = !menu.classList.contains('is-open');
      document.querySelectorAll('.lang-switcher-menu.is-open').forEach(m => {
        if (m !== menu) {
          m.classList.remove('is-open');
          const btn = m.parentElement.querySelector('.lang-switcher-button');
          if (btn) btn.setAttribute('aria-expanded', 'false');
        }
      });
      menu.classList.toggle('is-open', willOpen);
      button.setAttribute('aria-expanded', String(willOpen));
    });

    items.forEach(item => {
      item.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        const targetLocale = item.dataset.locale;
        if (!targetLocale) return;

        const currentLocale = getCurrentLocale();
        if (targetLocale === currentLocale) {
          menu.classList.remove('is-open');
          button.setAttribute('aria-expanded', 'false');
          return;
        }

        const targetUrl = getLocalizedPath(targetLocale);
        window.location.href = targetUrl;
      });
    });

    document.addEventListener('click', (e) => {
      if (!switcher.contains(e.target)) {
        menu.classList.remove('is-open');
        button.setAttribute('aria-expanded', 'false');
      }
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && menu.classList.contains('is-open')) {
        menu.classList.remove('is-open');
        button.setAttribute('aria-expanded', 'false');
      }
    });
  });
})();
</script>
