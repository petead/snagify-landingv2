<!-- ╔══ ROI CALCULATOR ══╗ -->
<section class="roi" id="roi">
  <div class="roi-inner">

    <div class="roi-head">
      <h2 class="reveal reveal-delay-1">Turn inspections <em>into revenue.</em></h2>
      <p class="roi-sub reveal reveal-delay-2"><strong>Stop inspecting for free.</strong> Bill the landlord, keep the margin.</p>
    </div>

    <div class="roi-widget reveal">
      <div class="roi-wg-left">
        <div class="roi-inputs">

          <div class="roi-slider-block">
            <div class="roi-slider-head">
              <span class="roi-slider-label">Inspections per month</span>
              <span class="roi-slider-value"><span id="roi-insp-val">20</span></span>
            </div>
            <input type="range" id="roi-insp" class="roi-slider" min="1" max="100" value="20" step="1" aria-label="Inspections per month">
            <div class="roi-slider-hint">Check-in or check-out = 1</div>
          </div>

          <div class="roi-slider-block">
            <div class="roi-slider-head">
              <span class="roi-slider-label">Your price per inspection</span>
              <span class="roi-slider-value"><span id="roi-bill-val">200</span><span class="unit">AED</span></span>
            </div>
            <input type="range" id="roi-bill" class="roi-slider" min="100" max="500" value="200" step="10" aria-label="Bill per inspection in AED">
            <div class="roi-slider-hint">Dubai average: 150–300 AED</div>
          </div>

          <button class="roi-math-toggle" id="roi-math-toggle" type="button" aria-expanded="false">
            Show me the math <span class="chev">▾</span>
          </button>
          <div class="roi-math" id="roi-math-box">
            <div class="roi-math-inner" id="roi-math-content"></div>
          </div>

        </div>
      </div>

      <div class="roi-wg-right">
        <div class="roi-result">
          <span class="roi-plan-badge" id="roi-plan-badge">Growth plan</span>
          <p class="roi-result-label">You keep</p>
          <div class="roi-big"><span class="aed">AED</span><span id="roi-take">45,012</span></div>
          <p class="roi-big-sub">per year, after costs</p>

          <div class="roi-break">
            <div class="roi-line plus">
              <span class="roi-line-label"><span class="roi-tick">+</span>Billed to landlords</span>
              <span class="roi-line-val">AED <span id="roi-rev">48,000</span></span>
            </div>
            <div class="roi-line minus">
              <span class="roi-line-label"><span class="roi-minus">−</span><span id="roi-plan-inline">Growth</span> plan</span>
              <span class="roi-line-val">AED <span id="roi-cost">2,988</span></span>
            </div>
            <div class="roi-line minus" id="roi-extra-line" style="display:none;">
              <span class="roi-line-label"><span class="roi-minus">−</span>Extra credits (<span id="roi-extra-n">0</span>)</span>
              <span class="roi-line-val">AED <span id="roi-extra">0</span></span>
            </div>
          </div>

          <div class="roi-multiplier">
            <span class="roi-multi-num" id="roi-mult">15.1×</span>
            <span class="roi-multi-text">your Snagify cost</span>
          </div>

          <a href="https://app.snagify.net" class="roi-cta" id="roi-cta" target="_blank" rel="noopener noreferrer">
            Start with <span id="roi-plan-cta">Growth</span> →
          </a>
        </div>
      </div>
    </div>

  </div>
</section>

