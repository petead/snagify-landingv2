<script is:inline>
(function() {
  var btn = document.getElementById('si-btn');
  var input = document.getElementById('si-email');
  var msg = document.getElementById('si-msg');
  if (!btn || !input) return;

  async function submit() {
    var email = (input.value || '').trim();
    var re = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    if (!re.test(email)) {
      msg.textContent = 'Please enter a valid email.';
      msg.style.color = '#FF5252';
      return;
    }
    btn.disabled = true;
    var original = btn.textContent;
    btn.textContent = '...';
    try {
      var eventId = (window.crypto && window.crypto.randomUUID)
        ? window.crypto.randomUUID()
        : String(Date.now()) + Math.random().toString(16).slice(2);

      var r = await fetch('/api/subscribe', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          email: email,
          eventId: eventId,
          eventSourceUrl: window.location.href,
        }),
      });

      if (r.ok && typeof window.fbq === 'function') {
        window.fbq('track', 'Lead', { content_name: 'newsletter' }, { eventID: eventId });
      }
      if (r.ok) {
        msg.textContent = "You're on the list — we'll be in touch.";
        msg.style.color = '#9A88FD';
        input.value = '';
      } else {
        msg.textContent = 'Something went wrong. Try again.';
        msg.style.color = '#FF5252';
      }
    } catch (e) {
      msg.textContent = 'Network error. Try again.';
      msg.style.color = '#FF5252';
    }
    btn.disabled = false;
    btn.textContent = original;
  }

  btn.addEventListener('click', submit);
  input.addEventListener('keydown', function(e) {
    if (e.key === 'Enter') submit();
  });
})();
</script>
<script>
// FAQ v2 — persona toggle + category tabs + accordion
(function(){
  const personas = document.querySelectorAll('.faq-persona-btn');
  const personaPanels = document.querySelectorAll('.faq-persona-panel');
  if (!personas.length) return;

  function closeItem(item) {
    item.classList.remove('open');
    const a = item.querySelector('.faq-a');
    if (a) a.style.maxHeight = '0px';
  }
  function openItem(item) {
    item.classList.add('open');
    const a = item.querySelector('.faq-a');
    if (a) a.style.maxHeight = a.scrollHeight + 'px';
  }

  personaPanels.forEach(pp => {
    const tabs = pp.querySelectorAll('.faq-tab');
    const panels = pp.querySelectorAll('.faq-panel');
    const items = pp.querySelectorAll('.faq-item');

    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        const target = tab.dataset.tab;
        tabs.forEach(t => t.classList.toggle('active', t === tab));
        panels.forEach(p => p.classList.toggle('active', p.dataset.panel === target));
        items.forEach(closeItem);
      });
    });

    items.forEach(item => {
      const q = item.querySelector('.faq-q');
      if (!q) return;
      q.addEventListener('click', () => {
        const wasOpen = item.classList.contains('open');
        const panel = item.closest('.faq-panel');
        panel.querySelectorAll('.faq-item.open').forEach(closeItem);
        if (!wasOpen) {
          openItem(item);
          requestAnimationFrame(() => {
            setTimeout(() => {
              const rect = item.getBoundingClientRect();
              const navH = 80;
              if (rect.top < navH) {
                const absoluteTop = window.scrollY + rect.top - navH - 16;
                window.scrollTo({ top: absoluteTop, behavior: 'smooth' });
              }
            }, 120);
          });
        }
      });
    });
  });

  personas.forEach(btn => {
    btn.addEventListener('click', () => {
      const target = btn.dataset.persona;
      personas.forEach(p => {
        const active = p === btn;
        p.classList.toggle('active', active);
        p.setAttribute('aria-selected', active ? 'true' : 'false');
      });
      personaPanels.forEach(pp => {
        const active = pp.dataset.personaPanel === target;
        pp.classList.toggle('active', active);
        if (active) {
          pp.querySelectorAll('.faq-tab').forEach((t, i) => t.classList.toggle('active', i === 0));
          pp.querySelectorAll('.faq-panel').forEach((p, i) => p.classList.toggle('active', i === 0));
          pp.querySelectorAll('.faq-item').forEach(closeItem);
        }
      });
    });
  });

  function activateFaqPersona(persona) {
    const btn = document.querySelector('.faq-persona-btn[data-persona="' + persona + '"]');
    if (btn && !btn.classList.contains('active')) btn.click();
  }

  function activateFaqTab(personaPanel, tabName) {
    const pp = document.querySelector('.faq-persona-panel[data-persona-panel="' + personaPanel + '"]');
    if (!pp) return;
    const tab = pp.querySelector('.faq-tab[data-tab="' + tabName + '"]');
    if (tab) tab.click();
  }

  function openFaqFromHash() {
    const hash = window.location.hash;
    if (hash !== '#faq-checkout-cost' && hash !== '#faq-credits-pro') return;
    const item = document.querySelector(hash);
    if (!item) return;

    if (hash === '#faq-checkout-cost') {
      activateFaqPersona('landlords');
      activateFaqTab('landlords', 'start');
    } else if (hash === '#faq-credits-pro') {
      activateFaqPersona('pros');
      activateFaqTab('pros', 'pricing');
    }

    setTimeout(() => {
      const panel = item.closest('.faq-panel');
      const pp = item.closest('.faq-persona-panel');
      if (pp && panel) {
        const tabName = panel.dataset.panel;
        const tab = pp.querySelector('.faq-tab[data-tab="' + tabName + '"]');
        if (tab && !tab.classList.contains('active')) tab.click();
      }
      if (panel) panel.querySelectorAll('.faq-item.open').forEach(closeItem);
      openItem(item);
      setTimeout(() => {
        const rect = item.getBoundingClientRect();
        const navH = 96;
        window.scrollTo({ top: Math.max(0, window.scrollY + rect.top - navH - 16), behavior: 'smooth' });
      }, 150);
    }, 80);
  }

  document.querySelectorAll('.price-faq-link').forEach(link => {
    link.addEventListener('click', e => {
      const href = link.getAttribute('href');
      if (!href || !href.startsWith('#faq-')) return;
      e.preventDefault();
      if (window.location.hash !== href) {
        window.location.hash = href;
      } else {
        openFaqFromHash();
      }
    });
  });

  window.addEventListener('hashchange', openFaqFromHash);
  if (window.location.hash === '#faq-checkout-cost' || window.location.hash === '#faq-credits-pro') {
    openFaqFromHash();
  }
})();
</script>
<script>
(function(){
  const sInsp = document.getElementById('roi-insp');
  const sBill = document.getElementById('roi-bill');
  if (!sInsp || !sBill) return;

  const rInspVal = document.getElementById('roi-insp-val');
  const rBillVal = document.getElementById('roi-bill-val');
  const rRev = document.getElementById('roi-rev');
  const rCost = document.getElementById('roi-cost');
  const rTake = document.getElementById('roi-take');
  const rMult = document.getElementById('roi-mult');
  const rPlanBadge = document.getElementById('roi-plan-badge');
  const rPlanInline = document.getElementById('roi-plan-inline');
  const rPlanCta = document.getElementById('roi-plan-cta');
  const rExtra = document.getElementById('roi-extra');
  const rExtraN = document.getElementById('roi-extra-n');
  const rExtraLine = document.getElementById('roi-extra-line');
  const mathToggle = document.getElementById('roi-math-toggle');
  const mathBox = document.getElementById('roi-math-box');
  const mathContent = document.getElementById('roi-math-content');

  const plans = {
    starter: { name: 'Starter', credits: 15, cost: 1788, extra: 28 },
    growth:  { name: 'Growth',  credits: 30, cost: 2988, extra: 22 },
    agency:  { name: 'Agency',  credits: 50, cost: 4488, extra: 16 }
  };

  function pickPlan(insp){
    if (insp <= 15) return plans.starter;
    if (insp <= 30) return plans.growth;
    return plans.agency;
  }

  function fmt(n){ return Math.round(n).toLocaleString('en-US'); }

  const prev = { rev: 48000, cost: 2988, take: 45012, extra: 0 };

  function animateTo(el, fromVal, toVal, duration){
    const start = performance.now();
    function tick(now){
      const t = Math.min(1, (now - start) / duration);
      const eased = 1 - Math.pow(1 - t, 3);
      const v = fromVal + (toVal - fromVal) * eased;
      el.textContent = fmt(v);
      if (t < 1) requestAnimationFrame(tick);
      else el.textContent = fmt(toVal);
    }
    requestAnimationFrame(tick);
  }

  function calc(){
    const insp = parseInt(sInsp.value, 10);
    const bill = parseInt(sBill.value, 10);

    rInspVal.textContent = insp;
    rBillVal.textContent = bill;

    const plan = pickPlan(insp);
    const rev = insp * 12 * bill;
    const creditsNeeded = insp * 12;
    const creditsIncluded = plan.credits * 12;
    const extraCredits = Math.max(0, creditsNeeded - creditsIncluded);
    const extraCost = extraCredits * plan.extra;
    const totalCost = plan.cost + extraCost;
    const take = rev - totalCost;
    const mult = take / plan.cost;

    rPlanBadge.textContent = plan.name + ' plan';
    rPlanInline.textContent = plan.name;
    rPlanCta.textContent = plan.name;

    animateTo(rRev, prev.rev, rev, 400);
    animateTo(rCost, prev.cost, plan.cost, 400);
    animateTo(rTake, prev.take, take, 500);

    rMult.textContent = mult.toFixed(1) + '×';

    if (extraCredits > 0) {
      rExtraLine.style.display = 'flex';
      rExtraN.textContent = extraCredits;
      animateTo(rExtra, prev.extra, extraCost, 400);
    } else {
      rExtraLine.style.display = 'none';
    }

    mathContent.innerHTML =
      'Revenue    : ' + insp + ' × 12 × ' + bill + ' AED = ' + fmt(rev) + ' AED<br>' +
      'Plan       : ' + plan.name + ' (' + plan.credits + ' credits/mo, ' + fmt(plan.cost) + ' AED/yr)<br>' +
      'Credits    : ' + creditsNeeded + '/yr needed, ' + creditsIncluded + ' included' +
      (extraCredits > 0 ? '<br>Extra      : ' + extraCredits + ' × ' + plan.extra + ' AED = ' + fmt(extraCost) + ' AED' : '') +
      '<br>Take-home  : ' + fmt(rev) + ' − ' + fmt(totalCost) + ' = <strong>' + fmt(take) + ' AED</strong>';

    if (mathToggle && mathToggle.classList.contains('open') && mathBox) {
      mathBox.style.maxHeight = mathContent.scrollHeight + 40 + 'px';
    }

    prev.rev = rev; prev.cost = plan.cost; prev.take = take; prev.extra = extraCost;
  }

  sInsp.addEventListener('input', calc);
  sBill.addEventListener('input', calc);

  if (mathToggle && mathBox) {
    mathToggle.addEventListener('click', () => {
      const open = mathToggle.classList.toggle('open');
      mathToggle.setAttribute('aria-expanded', open ? 'true' : 'false');
      mathBox.style.maxHeight = open ? (mathContent.scrollHeight + 40) + 'px' : '0px';
    });
  }

  calc();
})();
</script>

