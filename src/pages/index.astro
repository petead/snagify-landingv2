.pros-trip { position:relative; width:100%; max-width:470px; height:720px; margin:0 auto; }
.trip-card { position:absolute; width:360px; background:rgba(22,20,31,.85); border:1px solid rgba(255,255,255,.08); border-radius:20px; backdrop-filter:blur(12px); box-shadow:0 28px 70px rgba(0,0,0,.5); overflow:hidden; will-change:transform; }
.trip-1 { top:0; left:0; transform:rotate(-2.5deg); z-index:1; animation:tripFloat1 7s ease-in-out infinite; }
.trip-2 { top:236px; left:110px; transform:rotate(1.8deg); z-index:2; animation:tripFloat2 8s ease-in-out infinite 1.2s; }
.trip-3 { top:490px; left:10px; transform:rotate(-1.2deg); z-index:3; animation:tripFloat3 6.5s ease-in-out infinite 2.4s; }
@keyframes tripFloat1 {
  0%,100% { transform:rotate(-2.5deg) translateY(0); }
