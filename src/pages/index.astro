.trip-title { font-family:'Poppins',sans-serif; font-weight:700; font-size:16px; color:var(--white); letter-spacing:-.2px; margin-bottom:14px; }
/* mini report */
.trip-minirep { background:#FDFDFC; border-radius:12px; overflow:hidden; box-shadow:0 8px 24px rgba(0,0,0,.35); }
