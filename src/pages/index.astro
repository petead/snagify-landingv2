  z-index: 0;
}
/* Bridge toward pricing below */
.testi::after {
  content: '';
  position: absolute;
  bottom: 0; left: 0; right: 0;
  height: 100px;
  background: linear-gradient(to bottom, transparent, rgba(252,252,252,.07));
  pointer-events: none;
  z-index: 0;
}
.testi .section-wrap { position: relative; z-index: 1; }
.testi .section-title { color: var(--white); }
.testi .section-eyebrow { color: rgba(255,255,255,.5); }
.testi .section-eyebrow::before { background: rgba(255,255,255,.4); }

.testi-group-label {
  display: inline-flex; align-items: center; gap: 8px;
  font-size: 11px; text-transform: uppercase; letter-spacing: 2.5px;
  font-weight: 600; color: rgba(255,255,255,.35);
  margin-bottom: 20px;
}
.testi-group-label svg { opacity: .5; }

.testi-grid {
  display: grid;
