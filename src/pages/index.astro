---
import LanguageSwitcher from '../components/LanguageSwitcher.astro';
import CrispChat from '../components/CrispChat.astro';
import Clarity from '../components/Clarity.astro';
import GoogleAnalytics from '../components/GoogleAnalytics.astro';
import MetaPixel from '../components/MetaPixel.astro';
import Supademo from '../components/Supademo.astro';

const currentLocale = Astro.currentLocale || 'en';
const currentPath = Astro.url.pathname;
---
<!-- BEGIN: bit-perfect copy of original index.html -->
<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
<GoogleAnalytics />
<MetaPixel />
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
