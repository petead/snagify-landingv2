<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link rel="preload" href="/fonts/poppins-latin-800.woff2" as="font" type="font/woff2" crossorigin>
<link rel="preload" href="/fonts/poppins-latin-800-italic.woff2" as="font" type="font/woff2" crossorigin>
<style>
@font-face {
  font-family: 'Poppins';
  font-style: normal;
  font-weight: 800;
  font-display: swap;
  src: url('/fonts/poppins-latin-800.woff2') format('woff2');
  unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD;
}
@font-face {
  font-family: 'Poppins';
  font-style: italic;
  font-weight: 800;
  font-display: swap;
  src: url('/fonts/poppins-latin-800-italic.woff2') format('woff2');
  unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD;
}
</style>
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Poppins:ital,wght@0,400;0,500;0,700;1,700&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&display=swap" media="print" onload="this.media='all'">
<noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Poppins:ital,wght@0,400;0,500;0,700;1,700&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&display=swap"></noscript>
<style>
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

:root {
  --cream:    #F3F1EB;
  --cream-2:  #EAE8E0;
  --white:    #FCFCFC;
  --ink:      #0E0E10;
  --ink-60:   rgba(14,14,16,0.6);
  --ink-25:   rgba(14,14,16,0.1);
  --ink-08:   rgba(14,14,16,0.05);
  --purple:   #9A88FD;
  --purple-l: #C4B9FE;
  --purple-bg:#EDE9FE;
  --jasmine:  #FEDE80;
  --jasmine-bg:#FFF8DC;
  --green:    #CAFE87;
  --green-bg: #EEFAD5;
  --red:      #FF5252;
}

html { scroll-behavior: smooth; overflow-x: hidden; }
body {
  font-family: 'DM Sans', sans-serif;
  background: var(--cream);
  color: var(--ink);
  -webkit-font-smoothing: antialiased;
  cursor: none;
  overflow-x: hidden;
}
@media(max-width:1024px){ body { cursor: auto; } }

/* ══ CURSOR ══ */
#cur {
  width: 10px; height: 10px;
  background: var(--ink);
  border-radius: 50%;
  position: fixed !important;
  pointer-events: none !important;
  z-index: 99999;
  left: 0; top: 0;
  margin: 0; padding: 0;
  transform: translate(-50%, -50%);
  transition: background .25s, transform .2s;
  will-change: left, top;
}
#cur.big  { transform: translate(-50%, -50%) scale(1.4); }
#cur.light { background: var(--white); }
#cur.light.big { background: var(--purple-l); }
@media(max-width:1024px) { #cur { display: none !important; } }

/* ── SCROLL PROGRESS ── */
#prog { position:fixed;top:0;left:0;height:3px;background:var(--purple);z-index:9999;width:0;pointer-events:none; }

/* ══════════════════════════════════
   NAV
══════════════════════════════════ */
nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 1000;
  display: flex; align-items: center; justify-content: space-between;
  padding: 20px 48px;
  background: rgba(243,241,235,0);
  backdrop-filter: blur(0px) saturate(1);
  border-bottom: 1px solid transparent;
  transition:
    padding .5s cubic-bezier(.16,1,.3,1),
    background .5s ease,
    backdrop-filter .5s ease,
    border-color .4s ease,
    box-shadow .5s ease;
}
/* Floating pill — après scroll */
nav.scrolled {
  padding: 10px 20px;
  top: 12px;
  left: 50%;
  right: auto;
  transform: translateX(-50%);
  width: calc(100% - 64px);
  max-width: 1100px;
  background: rgba(243,241,235,0.92);
  backdrop-filter: blur(20px) saturate(1.4);
  border-radius: 999px;
  border-color: var(--ink-25);
  box-shadow: 0 4px 32px rgba(14,14,16,.1), 0 1px 0 rgba(255,255,255,.7) inset;
}
@media(max-width: 768px) {
  nav.scrolled {
    top: 0;
    left: 0;
    right: 0;
    transform: none;
    width: 100%;
    border-radius: 0;
    padding: 12px 20px;
  }
}
nav.scrolled .nav-links a { font-size: 13px; }
nav.scrolled .nav-logo span { font-size: 18px; }
nav.scrolled .nav-logo svg { width: 28px; height: 28px; }

/* État initial : nav pleine largeur transparente */
nav:not(.scrolled) {
  background: rgba(243,241,235,0);
  border-color: transparent;
  box-shadow: none;
}
.nav-logo { display:flex;align-items:center;gap:9px;text-decoration:none; }
.nav-logo span { font-family:'Poppins',sans-serif;font-weight:800;font-size:20px;color:var(--ink);letter-spacing:-0.5px; }
.nav-links { display:flex;align-items:center;gap:32px;list-style:none; }
.nav-links a { color:var(--ink-60);text-decoration:none;font-size:14px;font-weight:500;transition:color .25s; }
.nav-links a:hover { color:var(--ink); }

/* ── PWA INSTALL STRIP ── */
/* ── MOB DRAWER LINKS ── */
.mob-link {
  font-family: 'Poppins', sans-serif;
  font-weight: 800;
  font-size: 26px;
  color: #0E0E10;
  text-decoration: none;
  letter-spacing: -0.5px;
  padding: 8px 0;
  display: block;
  transition: color .2s;
}
.mob-link:hover { color: #9A88FD; }
.mob-cta {
  margin-top: 8px;
  padding: 14px 36px !important;
  background: #0E0E10 !important;
  color: #FCFCFC !important;
  border-radius: 999px !important;
  font-size: 16px !important;
}
.mob-cta:hover,
.mob-cta:visited,
.mob-cta:active {
  background: #9A88FD !important;
  color: #0E0E10 !important;
}
a.mob-link.mob-cta { color: #FCFCFC !important; }
a.mob-link.mob-cta:hover { color: #0E0E10 !important; }
/* ── HAMBURGER BUTTON ── */
/* Hamburger */
.nav-burger {
  display: none;
  flex-direction: column; justify-content: center; gap: 5px;
  width: 36px; height: 36px;
  background: none; border: none; cursor: pointer; padding: 4px;
}
.nav-burger span {
  display: block; height: 2px; background: var(--ink);
  border-radius: 2px;
  transition: transform .3s ease, opacity .3s ease, width .3s ease;
  transform-origin: center;
}
.nav-burger.is-open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
.nav-burger.is-open span:nth-child(2) { opacity: 0; }
.nav-burger.is-open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

/* ── MOBILE DRAWER ── */
.nav-drawer {
  display: flex !important;
  flex-direction: column !important;
  align-items: center !important;
  justify-content: center !important;
  gap: 4px;
  position: fixed !important;
  top: 0 !important; left: 0 !important;
  right: 0 !important; bottom: 0 !important;
  width: 100% !important; height: 100% !important;
  background-color: #F3F1EB !important;
  background-image: none !important;
  z-index: 10000 !important;
  opacity: 0;
  visibility: hidden;
  pointer-events: none;
  transition: opacity .25s ease, visibility .25s ease;
}
.nav-drawer.is-open {
  opacity: 1 !important;
  visibility: visible !important;
  pointer-events: all !important;
}
/* Blindage fond drawer — neutralise nav:not(.scrolled) */
div#nav-drawer,
div#nav-drawer.nav-drawer,
div#nav-drawer.is-open {
  background-color: #F3F1EB !important;
  background-image: none !important;
  background: #F3F1EB !important;
}
div#nav-drawer .drawer-link,
div#nav-drawer a {
  color: #0E0E10 !important;
  opacity: 1 !important;
  visibility: visible !important;
}
.nav-drawer .drawer-link,
.nav-drawer a {
  font-family: 'Poppins', sans-serif !important;
  font-weight: 800 !important;
  font-size: 28px !important;
  color: #0E0E10 !important;
  text-decoration: none !important;
  letter-spacing: -0.5px;
  padding: 8px 0 !important;
  transition: color .2s;
  display: block !important;
  opacity: 1 !important;
  visibility: visible !important;
}
.nav-drawer .drawer-link:hover,
.nav-drawer a:hover { color: #9A88FD !important; }
.nav-drawer .drawer-divider {
  width: 40px; height: 1.5px;
  background: rgba(14,14,16,.12); margin: 10px 0;
}
.nav-drawer .drawer-cta {
  margin-top: 20px;
  padding: 14px 36px;
  background: #0E0E10; color: #FCFCFC !important;
  border-radius: 999px; font-size: 16px;
}
.nav-drawer .drawer-cta:hover { background: var(--purple); color: #0E0E10 !important; }

/* Bouton close (X) dans le drawer */
.drawer-close {
  position: absolute; top: 20px; right: 20px;
  width: 40px; height: 40px;
  background: rgba(14,14,16,.07);
  border: none; border-radius: 50%;
  cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  transition: background .2s;
}
.drawer-close:hover { background: rgba(14,14,16,.14); }
.drawer-close svg { pointer-events: none; }
.nav-pill {
  padding: 9px 18px;
  background: var(--ink); color: var(--white)!important;
  border-radius: 999px; font-weight: 700!important; font-size: 13px;
  transition: background .3s, transform .3s cubic-bezier(.16,1,.3,1), box-shadow .3s!important;
  display: inline-flex!important; align-items: center!important; gap: 7px!important;
}
.nav-pill:hover {
  background: var(--purple)!important;
  transform: translateY(-2px)!important;
  color: var(--ink)!important;
  box-shadow: 0 8px 20px rgba(154,136,253,.3)!important;
}
.nav-pill:hover .nav-pill-dot { background: var(--ink)!important; }

/* Dot live vert pulsé */
.nav-pill-dot {
  width: 6px; height: 6px; border-radius: 50%;
  background: var(--green);
  flex-shrink: 0;
  box-shadow: 0 0 0 0 rgba(202,254,135,.5);
  animation: navDotPulse 2s ease-out infinite;
}
@keyframes navDotPulse {
  0%   { box-shadow: 0 0 0 0 rgba(202,254,135,.5); }
  60%  { box-shadow: 0 0 0 5px rgba(202,254,135,0); }
  100% { box-shadow: 0 0 0 0 rgba(202,254,135,0); }
}

/* Transition logo size smooth */
.nav-logo svg { transition: width .4s ease, height .4s ease; }
.nav-logo span { transition: font-size .4s ease; }

/* ══════════════════════════════════
   HERO
══════════════════════════════════ */
.hero {
  min-height: 100vh;
  display: flex; align-items: center;
  padding: 88px 48px 72px;
  position: relative; overflow: hidden;
}

/* Hero atmosphere — dramatic depth */
.hero::before {
  content: '';
  position: absolute; inset: 0; z-index: 0;
  background-image: radial-gradient(circle, rgba(14,14,16,.07) 1px, transparent 1px);
  background-size: 28px 28px;
  mask-image: radial-gradient(ellipse 100% 100% at 50% 50%, black 0%, transparent 75%);
  pointer-events: none;
}
.hero::after {
  content: '';
  position: absolute; inset: 0; z-index: 0; pointer-events: none;
  background:
    radial-gradient(ellipse 70% 65% at 78% 58%, rgba(154,136,253,.18) 0%, transparent 60%),
    radial-gradient(ellipse 50% 45% at 18% 72%, rgba(202,254,135,.1) 0%, transparent 55%),
    radial-gradient(ellipse 40% 35% at 55% 10%, rgba(254,222,128,.09) 0%, transparent 50%),
    radial-gradient(ellipse 35% 30% at 90% 15%, rgba(154,136,253,.08) 0%, transparent 50%);
}

/* Decorative watermark — plus présent, repositionné */
.hero-watermark {
  position: absolute;
  right: -80px; top: 50%;
  transform: translateY(-52%);
  font-family: 'Poppins', sans-serif; font-weight: 800;
  font-size: 520px; line-height: 1;
  color: transparent;
  -webkit-text-stroke: 1.5px rgba(154,136,253,.08);
  letter-spacing: -36px;
  pointer-events: none; z-index: 0;
  user-select: none;
  /* Subtle gradient fade sur les bords */
  mask-image: radial-gradient(ellipse 80% 80% at 60% 50%, black 30%, transparent 80%);
}

.hero-inner {
  max-width: 1360px; margin: 0 auto; width: 100%;
  display: grid; grid-template-columns: 1fr 1fr;
  gap: 80px; align-items: center;
  position: relative; z-index: 2;
}

/* ── Left content ── */
.hero-left { position: relative; overflow: visible; }

.hero-eyebrow {
  display: inline-flex; align-items: center; gap: 8px;
  font-size: 11px; text-transform: uppercase; letter-spacing: 3.5px; font-weight: 500;
  color: var(--ink-60); margin-bottom: 20px;
}
.eyebrow-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--purple); animation: eyePulse 2s ease-in-out infinite; }
@keyframes eyePulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:.5;transform:scale(0.7)} }

.hero h1 {
  font-family: 'Poppins', sans-serif; font-weight: 800;
  font-size: clamp(56px, 6vw, 88px);
  line-height: 1.02; letter-spacing: -3.5px;
  margin-bottom: 10px;
}
.hero h1 em { font-style: italic; color: var(--purple); }

/* Line-by-line animation */
.line-wrap { overflow: hidden; padding-bottom: 0.14em; margin-bottom: -0.06em; }
.hero h1 .line-wrap:last-child { padding-bottom: 0.22em; margin-bottom: 0; }
.line-inner {
  display: inline-block;
  transform: translateY(110%);
  animation: lineUp .9s cubic-bezier(.16,1,.3,1) forwards;
}
.hero h1 .line-wrap:nth-child(1) .line-inner { animation-delay: .1s; }
.hero h1 .line-wrap:nth-child(2) .line-inner { animation-delay: .22s; }
.hero h1 .line-wrap:nth-child(3) .line-inner { animation-delay: .32s; }
@keyframes lineUp { to { transform: translateY(0); } }

.hero-cta-group {
  display: inline-flex;
  align-items: center;
  gap: 12px;
  flex-wrap: nowrap;
  position: relative;
}
.hero-cta-group .btn-ink,
.hero-cta-group .btn-ghost {
  width: auto;
  flex: 0 0 auto;
}
.hero-ph--cta {
  display: inline-flex;
  align-items: center;
  flex: 0 0 auto;
  margin-right: clamp(-72px, -7vw, -28px);
  opacity: 0;
  animation: fadeIn .55s ease 1.15s forwards;
  transition: transform .3s cubic-bezier(.16,1,.3,1);
}
.hero-ph--cta:hover { transform: translateY(-3px); }
.hero-ph--cta img { display: block; width: auto; height: clamp(38px, 4.5vw, 50px); }
.hero-stats {
  display: flex;
  align-items: center;
  gap: 28px;
  padding: 16px 0;
  margin-bottom: 28px;
  border-top: 1px solid var(--ink-25);
  border-bottom: 1px solid var(--ink-25);
  opacity: 0;
  animation: fadeIn .6s ease .5s forwards;
}
.hstat { display: flex; flex-direction: column; gap: 2px; }
.hstat-num {
  font-family: 'Poppins', sans-serif; font-weight: 800;
  font-size: 22px; letter-spacing: -1px; line-height: 1;
}
.hstat-lbl { font-size: 11px; text-transform: uppercase; letter-spacing: 2px; color: var(--ink-60); font-weight: 500; }
.hstat-div { width: 1px; height: 36px; background: var(--ink-25); }

.hero-desc {
  font-size: 17px; color: var(--ink-60); line-height: 1.75;
  max-width: 460px; margin-bottom: 40px; font-weight: 400;
  opacity: 0; animation: fadeIn .7s ease .95s forwards;
}

.hero-actions {
  display: flex;
  flex-direction: column;
  gap: 14px;
  align-items: flex-start;
  overflow: visible;
  opacity: 0;
  animation: fadeIn .7s ease 1.1s forwards;
}
.hero-ph {
  display: inline-flex;
  align-items: center;
  align-self: center;
  margin-top: 6px;
  transition: transform .25s ease;
}
.hero-ph:hover { transform: translateY(-2px); }
.hero-ph img { display: block; width: auto; height: 48px; }
.hero-sample-link {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  font-size: 13px;
  font-weight: 500;
  color: var(--ink-60);
  text-decoration: none;
  border-bottom: 1px dashed var(--ink-25);
  padding-bottom: 2px;
  transition: color .25s, border-color .25s;
}
.hero-sample-link:hover {
  color: var(--purple);
  border-color: var(--purple);
}

.btn-ink {
  display: inline-flex; align-items: center; gap: 10px;
  padding: 15px 30px; background: var(--ink); color: var(--white);
  font-family: 'Poppins', sans-serif; font-weight: 700; font-size: 15px;
  border-radius: 999px; text-decoration: none; border: none; cursor: pointer;
  transition: background .35s, transform .35s cubic-bezier(.16,1,.3,1), box-shadow .35s;
  position: relative; overflow: hidden;
}
.btn-ink::after {
  content: '';
  position: absolute; inset: 0; border-radius: 999px;
  background: linear-gradient(135deg, rgba(255,255,255,.08), transparent);
  opacity: 0; transition: opacity .3s;
}
.btn-ink:hover { background: var(--purple); color: var(--ink); transform: translateY(-4px); box-shadow: 0 16px 40px rgba(154,136,253,.4); }
.btn-ink:hover::after { opacity: 1; }
.btn-ink:active { transform: translateY(-1px); }

.btn-ghost {
  display: inline-flex; align-items: center; gap: 10px;
  padding: 15px 30px; background: transparent; color: var(--ink);
  font-family: 'Poppins', sans-serif; font-weight: 600; font-size: 15px;
  border-radius: 999px; text-decoration: none; border: 1.5px solid var(--ink-25);
  transition: border-color .3s, transform .3s; cursor: pointer;
}
.btn-ghost:hover { border-color: var(--ink); transform: translateY(-3px); }

/* ── Right: Inspection Card Visual ── */
.hero-right {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  opacity: 0;
  animation: cardReveal 1s cubic-bezier(.16,1,.3,1) .35s forwards;
  padding-right: 60px;
  padding-left: 20px;
}
@keyframes cardReveal { from{opacity:0;transform:translateY(24px) rotate(-3deg)} to{opacity:1;transform:translateY(0) rotate(-2deg)} }

/* Back shadow cards — two layers for depth */
.insp-card-back {
  position: absolute;
  width: min(380px, calc(100vw - 40px));
  background: linear-gradient(145deg, #FEDE80, #FEC94A);
  border-radius: 28px;
  height: 520px;
  transform: rotate(5.5deg) translateY(14px) translateX(6px);
  z-index: 0;
  right: 0;
  box-shadow: 0 32px 80px rgba(254,201,74,.3), 0 8px 20px rgba(14,14,16,.12);
  border: 1px solid rgba(14,14,16,.05);
}
.insp-card-back::before {
  content: '';
  position: absolute;
  inset: -1px;
  border-radius: 28px;
  background: linear-gradient(145deg, #9A88FD, #C4B9FE);
  transform: rotate(-8deg) translateY(8px) translateX(-12px);
  z-index: -1;
  opacity: .25;
  box-shadow: 0 20px 60px rgba(154,136,253,.2);
}

/* Main inspection card */
.insp-card {
  width: min(380px, calc(100vw - 40px));
  background: var(--white);
  border-radius: 28px;
  border: 1px solid rgba(154,136,253,.2);
  box-shadow:
    0 60px 120px rgba(14,14,16,.2),
    0 24px 40px rgba(14,14,16,.1),
    0 0 0 1px rgba(154,136,253,.08),
    0 -4px 80px rgba(154,136,253,.12),
    inset 0 1px 0 rgba(255,255,255,.9);
  overflow: hidden;
  position: relative; z-index: 2;
  transform: rotate(-2deg);
  animation: cardFloat 7s ease-in-out infinite .5s;
}
@keyframes cardFloat {
  0%,100% { transform: rotate(-2deg) translateY(0); }
  50% { transform: rotate(-2deg) translateY(-14px); }
}

/* iPhone screenshot frame */
.iphone-shot {
  --iphone-w: 220px;
  position: relative;
  width: var(--iphone-w);
  margin: 0 auto;
  background: linear-gradient(155deg, #35353d, #101014);
  border-radius: calc(var(--iphone-w) * 0.17);
  padding: calc(var(--iphone-w) * 0.038);
  box-shadow:
    0 28px 70px rgba(14,14,16,.22),
    0 8px 20px rgba(14,14,16,.12),
    inset 0 0 0 1px rgba(255,255,255,.1);
}
.iphone-shot::before {
  content: '';
  position: absolute;
  top: calc(var(--iphone-w) * 0.028);
  left: 50%;
  transform: translateX(-50%);
  width: calc(var(--iphone-w) * 0.34);
  height: calc(var(--iphone-w) * 0.062);
  background: #101014;
  border-radius: 0 0 12px 12px;
  z-index: 3;
}
.iphone-shot-screen {
  border-radius: calc(var(--iphone-w) * 0.13);
  overflow: hidden;
  background: #000;
  aspect-ratio: 390 / 844;
}
.iphone-shot-screen img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: top center;
  display: block;
}
.iphone-shot-hiw { --iphone-w: 196px; }
.iphone-shot-sm { --iphone-w: 128px; }
.b-ai .iphone-shot-sm { --iphone-w: 200px; }
.b-ghost .iphone-shot-sm,
.b-contract .iphone-shot-sm,
.b-cmp .iphone-shot-sm,
.b-inventory .iphone-shot-sm { --iphone-w: 200px; }
.bento-card .iphone-shot-screen img {
  object-fit: contain;
  object-position: center top;
  background: #0e0e10;
}

/* Card header */
.ic-header {
  display: flex; align-items: flex-start; justify-content: space-between;
  padding: 22px 22px 16px;
  border-bottom: 1px solid var(--ink-25);
}
.ic-prop-name { font-family: 'Poppins', sans-serif; font-weight: 700; font-size: 15px; margin-bottom: 2px; }
.ic-prop-sub { font-size: 12px; color: var(--ink-60); display: flex; align-items: center; gap: 6px; }
.ic-dot { width: 4px; height: 4px; border-radius: 50%; background: var(--ink-25); }

.ic-badge {
  display: inline-flex; align-items: center; gap: 5px;
  font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 1.5px;
  padding: 5px 10px; border-radius: 999px;
  background: var(--purple-bg); color: var(--purple);
  flex-shrink: 0;
}
.ic-badge-dot { width: 5px; height: 5px; border-radius: 50%; background: var(--purple); animation: eyePulse 1.5s infinite; }

/* Photo area with AI pins */
.ic-photo {
  position: relative; height: 160px; overflow: hidden;
  background: linear-gradient(135deg, #c9c4f5 0%, #e4dffe 35%, #f0ecff 60%, #e8f5e0 100%);
}
.ic-photo-texture {
  position: absolute; inset: 0;
  background:
    radial-gradient(circle at 30% 40%, rgba(154,136,253,.3) 0%, transparent 50%),
    radial-gradient(circle at 75% 70%, rgba(202,254,135,.25) 0%, transparent 40%);
}

/* AI analysis overlay */
.ic-ai-bar {
  position: absolute; top: 12px; left: 12px;
  display: flex; align-items: center; gap: 6px;
  background: rgba(14,14,16,.7); backdrop-filter: blur(8px);
  border-radius: 8px; padding: 6px 10px;
  font-size: 11px; font-weight: 600; color: var(--white);
}
.ic-ai-blink { width: 6px; height: 6px; border-radius: 50%; background: var(--green); animation: eyePulse 1s infinite; }

/* Damage pin markers */
.ic-pin {
  position: absolute;
  display: flex; align-items: center; gap: 6px;
  animation: pinPop .4s cubic-bezier(.34,1.56,.64,1) forwards;
  opacity: 0;
}
.ic-pin-1 { left: 28%; top: 45%; animation-delay: 1.4s; }
.ic-pin-2 { left: 62%; top: 62%; animation-delay: 1.7s; }
@keyframes pinPop { from{opacity:0;transform:scale(0.4)} to{opacity:1;transform:scale(1)} }
@keyframes aiScan {
  0%   { top: 10%; opacity: 0; }
  10%  { opacity: 1; }
  90%  { opacity: 1; }
  100% { top: 90%; opacity: 0; }
}

.ic-pin-dot {
  width: 14px; height: 14px; border-radius: 50%;
  background: rgba(255,82,82,.9); border: 2px solid white;
  box-shadow: 0 2px 8px rgba(255,82,82,.4);
  flex-shrink: 0;
}
.ic-pin-label {
  background: rgba(14,14,16,.75); backdrop-filter: blur(8px);
  color: white; font-size: 10px; font-weight: 600;
  padding: 3px 8px; border-radius: 6px; white-space: nowrap;
}

/* Rooms grid */
.ic-rooms { padding: 16px 22px; }
.ic-rooms-title {
  font-size: 10px; text-transform: uppercase; letter-spacing: 2px;
  color: var(--ink-60); font-weight: 600; margin-bottom: 12px;
}
.ic-room-row {
  display: flex; align-items: center; gap: 12px;
  padding: 9px 0;
  border-bottom: 1px solid var(--ink-25);
}
.ic-room-row:last-child { border-bottom: none; }

.ic-room-icon {
  width: 28px; height: 28px; border-radius: 8px;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.ic-room-icon svg { width: 14px; height: 14px; }
.ri-purple { background: var(--purple-bg); color: var(--purple); }
.ri-green  { background: var(--green-bg);  color: #4A8A00; }
.ri-yellow { background: var(--jasmine-bg);color: #8A6000; }

.ic-room-name { font-size: 13px; font-weight: 500; flex: 1; }

.ic-room-bar-wrap { width: 80px; }
.ic-room-bar {
  height: 4px; background: var(--ink-25); border-radius: 9px; overflow: hidden;
}
.ic-room-bar-fill { height: 100%; border-radius: 9px; }
.bar-good { background: var(--green); width: 88%; }
.bar-fair { background: var(--jasmine); width: 58%; }

.ic-room-badge {
  font-size: 10px; font-weight: 700; padding: 3px 8px;
  border-radius: 999px; width: 44px; text-align: center; flex-shrink: 0;
}
.bdg-good { background: var(--green-bg);   color: #4A8A00; }
.bdg-fair { background: var(--jasmine-bg); color: #8A6000; }

/* Card footer */
.ic-footer {
  padding: 14px 22px;
  background: var(--cream);
  border-top: 1px solid var(--ink-25);
  display: flex; align-items: center; justify-content: space-between;
}
.ic-progress {
  display: flex; flex-direction: column; gap: 4px;
}
.ic-progress-text { font-size: 11px; color: var(--ink-60); }
.ic-progress-bar { width: 120px; height: 4px; background: var(--ink-25); border-radius: 9px; overflow: hidden; }
.ic-progress-fill { height: 100%; width: 70%; background: var(--purple); border-radius: 9px; }

.ic-gen-btn {
  display: inline-flex; align-items: center; gap: 6px;
  padding: 8px 14px; background: var(--ink); color: var(--white);
  font-family: 'Poppins', sans-serif; font-weight: 700; font-size: 12px;
  border-radius: 999px; text-decoration: none;
}

/* Float tags around the card */
.hero-tag {
  position: absolute;
  background: var(--white); border-radius: 14px;
  padding: 9px 14px;
  display: flex; align-items: center; gap: 8px;
  font-size: 12px; font-weight: 600;
  box-shadow:
    0 12px 40px rgba(14,14,16,.12),
    0 2px 8px rgba(14,14,16,.06),
    inset 0 1px 0 rgba(255,255,255,.9);
  border: 1px solid var(--ink-25); white-space: nowrap; z-index: 3;
  opacity: 0; animation: fadeInTag .6s cubic-bezier(.16,1,.3,1) forwards;
}
.ht1 { top: 30px; left: -50px; animation-delay: 1.6s; }
.ht2 { top: 50%; right: -60px; animation-delay: 1.9s; transform: translateY(-50%); }
.ht3 { bottom: 60px; left: -40px; animation-delay: 2.1s; }
@keyframes fadeInTag {
  from { opacity: 0; transform: translateY(12px) scale(.95); }
  to   { opacity: 1; transform: translateY(0) scale(1); }
}
.ht2 { animation-name: fadeInTagRight; }
@keyframes fadeInTagRight {
  from { opacity: 0; transform: translateY(-50%) translateX(12px) scale(.95); }
  to   { opacity: 1; transform: translateY(-50%) translateX(0) scale(1); }
}

.htag-ico {
  width: 26px; height: 26px; border-radius: 7px;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.htag-ico svg { width: 13px; height: 13px; }

/* ── Shared animations ── */
@keyframes fadeIn { to { opacity: 1; } }

/* ══════════════════════════════════
   MARQUEE
══════════════════════════════════ */
.marquee-band {
  background: var(--purple); padding: 18px 0; overflow: hidden;
}
.marquee-track { display: flex; width: max-content; animation: marquee 24s linear infinite; }
.marquee-item {
  display: flex; align-items: center; gap: 12px; padding: 0 36px;
  font-size: 13px; font-weight: 600; text-transform: uppercase; letter-spacing: 2px;
  color: var(--ink); white-space: nowrap; font-family: 'Poppins', sans-serif;
}
.marquee-sep { width: 5px; height: 5px; border-radius: 50%; background: var(--ink); opacity: .4; }
@keyframes marquee { from{transform:translateX(0)} to{transform:translateX(-50%)} }
.marquee-track { animation-duration: 18s !important; }

/* ══════════════════════════════════
   SECTION BASE
══════════════════════════════════ */
.section-wrap { max-width: 1360px; margin: 0 auto; padding: 0 48px; }
.section-header { margin-bottom: 64px; }
.section-eyebrow {
  display: inline-flex; align-items: center; gap: 8px;
  font-size: 11px; text-transform: uppercase; letter-spacing: 3.5px;
  color: var(--ink-60); font-weight: 500; margin-bottom: 16px;
}
.section-eyebrow::before { content: ''; width: 20px; height: 1.5px; background: var(--ink-60); }
.section-title {
  font-family: 'Poppins', sans-serif; font-weight: 800;
  font-size: clamp(36px,4vw,58px); line-height: 1.04; letter-spacing: -2px;
  margin-bottom: 16px;
}
.section-title em { font-style: italic; color: var(--purple); }
.section-sub { font-size: 17px; color: var(--ink-60); max-width: 480px; line-height: 1.7; }

/* ══ FEATURES — DECK-STYLE SLIDES ══ */
.features { padding: 80px 0 120px; }

.deck-prez {
  display: flex;
  flex-direction: column;
  gap: 20px;
  margin-bottom: 48px;
}
.deck-slide {
  --deck-accent: var(--purple);
  --deck-accent-soft: #C4B9FE;
  position: relative;
  display: flex;
  align-items: center;
  gap: clamp(28px, 5vw, 56px);
  padding: clamp(36px, 5vw, 64px) clamp(28px, 4vw, 56px);
  border-radius: 28px;
  overflow: hidden;
  background: linear-gradient(150deg, #0E0E10, #14121C);
  color: #F8F7F4;
  border: 1px solid rgba(255,255,255,.06);
}
.deck-slide::before {
  content: '';
  position: absolute;
  width: min(900px, 80vw);
  height: min(900px, 80vw);
  border-radius: 50%;
  background: radial-gradient(circle, var(--deck-accent) 0%, transparent 62%);
  opacity: .12;
  pointer-events: none;
  z-index: 0;
}
.deck-slide:nth-child(odd)::before { top: -40%; right: -20%; }
.deck-slide:nth-child(even)::before { bottom: -40%; left: -20%; }
.deck-slide--reverse { flex-direction: row-reverse; }
.deck-slide-copy,
.deck-slide-visual { position: relative; z-index: 1; }
.deck-slide-copy {
  flex: 1 1 44%;
  min-width: 0;
  max-width: 620px;
}
.deck-slide-visual {
  flex: 1 1 48%;
  display: flex;
  justify-content: center;
  align-items: center;
  min-width: 0;
}
.deck-slide-label {
  display: flex;
  align-items: center;
  gap: 14px;
  margin-bottom: 8px;
}
.deck-slide-num {
  width: 44px; height: 44px;
  border-radius: 13px;
  background: var(--deck-accent);
  color: #0E0E10;
  font-family: 'Poppins', sans-serif;
  font-weight: 800;
  font-size: 20px;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.deck-slide-eyebrow {
  font-family: 'Poppins', sans-serif;
  font-weight: 600;
  font-size: 13px;
  letter-spacing: .14em;
  text-transform: uppercase;
  color: var(--deck-accent-soft);
}
.deck-slide-title {
  font-family: 'Poppins', sans-serif;
  font-weight: 800;
  font-size: clamp(30px, 3.6vw, 52px);
  line-height: 1.08;
  letter-spacing: -.02em;
  margin: 20px 0 0;
  color: #F8F7F4;
}
.deck-slide-title em {
  font-style: italic;
  color: var(--deck-accent);
}
.deck-slide-lead {
  font-size: clamp(15px, 1.5vw, 18px);
  line-height: 1.55;
  color: rgba(248,247,244,.55);
  margin: 18px 0 0;
  max-width: 540px;
}
.deck-subcards {
  margin-top: 28px;
  display: flex;
  flex-direction: column;
  gap: 12px;
}
.deck-subcard {
  display: flex;
  gap: 16px;
  align-items: flex-start;
  padding: 16px 18px;
  border-radius: 16px;
  background: rgba(255,255,255,.025);
  border: 1px solid #262234;
}
.deck-subcard-ico {
  width: 44px; height: 44px;
  flex: none;
  border-radius: 13px;
  background: color-mix(in srgb, var(--deck-accent) 14%, transparent);
  border: 1px solid color-mix(in srgb, var(--deck-accent) 28%, transparent);
  display: flex; align-items: center; justify-content: center;
  color: var(--deck-accent-soft);
}
.deck-subcard-ico svg { width: 20px; height: 20px; stroke: currentColor; fill: none; }
.deck-subcard h4 {
  font-family: 'Poppins', sans-serif;
  font-weight: 600;
  font-size: 15px;
  letter-spacing: -.01em;
  margin: 0 0 4px;
  color: #F8F7F4;
}
.deck-subcard p {
  font-size: 14px;
  line-height: 1.4;
  color: rgba(248,247,244,.55);
  margin: 0;
}

/* Deck phone pair */
.deck-phones {
  display: flex;
  align-items: flex-end;
  justify-content: center;
  gap: 0;
  padding: 8px 0;
}
.deck-phone {
  --deck-phone-w: clamp(148px, 18vw, 240px);
  width: var(--deck-phone-w);
  flex: none;
  background: #24222F;
  border-radius: calc(var(--deck-phone-w) * 0.133);
  padding: calc(var(--deck-phone-w) * 0.033);
  box-shadow:
    0 28px 56px rgba(0,0,0,.55),
    0 4px 12px rgba(0,0,0,.35),
    0 0 0 1px #2C2939;
}
.deck-phone--left {
  transform: rotate(-4deg);
  z-index: 2;
  margin-right: -12px;
}
.deck-phone--right {
  transform: rotate(4deg);
  z-index: 1;
  margin-left: -12px;
}
.deck-phone-screen {
  border-radius: calc(var(--deck-phone-w) * 0.106);
  overflow: hidden;
  background: #0E0E14;
  aspect-ratio: 390 / 844;
}
.deck-phone-screen img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: top center;
  display: block;
}

.bento-pro { margin-top: 8px; }

@media (max-width: 960px) {
  .deck-slide,
  .deck-slide--reverse {
    flex-direction: column;
    text-align: center;
    padding: 32px 24px;
  }
  .deck-slide-copy { max-width: none; }
  .deck-slide-lead { margin-left: auto; margin-right: auto; }
  .deck-slide-label { justify-content: center; }
  .deck-subcards { text-align: left; }
  .deck-phone--left { margin-right: -8px; }
  .deck-phone--right { margin-left: -8px; }
}
@media (max-width: 768px) {
  .deck-slide,
  .deck-slide--reverse { padding: 28px 20px; }

  /* Sub-cards: slim one-liner rows, descriptions hidden */
  .deck-subcards { gap: 8px; margin-top: 20px; }
  .deck-subcard { padding: 10px 14px; align-items: center; }
  .deck-subcard p { display: none; }
  .deck-subcard h4 { font-size: 14px; margin: 0; }
  .deck-subcard-ico { width: 32px; height: 32px; }
  .deck-subcard-ico svg { width: 15px; height: 15px; }

  /* Phones: smaller floor, kill the transform hack */
  .deck-phones { transform: none; }
  .deck-phone { --deck-phone-w: 126px; }

  /* Lead a touch tighter */
  .deck-slide-lead { font-size: 15px; }
}

/* ══ FEATURES BENTO (pro extras) ══ */
.bento {
  display: grid;
  grid-template-columns: repeat(12, 1fr);
  gap: 16px;
}
/* ── Base card ── */
.bento-card {
  background: var(--white);
  border-radius: 24px;
  border: 1px solid var(--ink-25);
  padding: 30px;
  position: relative;
  overflow: hidden;
  transition: transform .4s cubic-bezier(.16,1,.3,1), box-shadow .4s, border-color .4s;
}
.bento-card:hover {
  transform: translateY(-5px);
  box-shadow: 0 20px 44px -20px rgba(14,14,16,.22);
  border-color: var(--purple-l);
}
.bento-card h3 {
  font-family: 'Poppins', sans-serif; font-weight: 600;
  font-size: 20px; letter-spacing: -.01em; margin-bottom: 8px; color: var(--ink);
}
.bento-card p { font-size: 15px; line-height: 1.55; color: var(--ink-60); }
.bc-eyebrow {
  display: inline-flex; align-items: center; gap: 6px;
  font-family: 'Poppins', sans-serif; font-weight: 600; font-size: 11px;
  letter-spacing: .1em; text-transform: uppercase; color: var(--ink-60);
  margin-bottom: 12px;
}
.bc-eyebrow.bc-pro::after {
  content: "PRO"; background: var(--jasmine-bg); color: #B08900;
  padding: 2px 7px; border-radius: 6px; font-size: 10px; letter-spacing: .06em;
}
.bc-icon {
  width: 38px; height: 38px; border-radius: 11px;
  display: flex; align-items: center; justify-content: center; margin-bottom: 16px;
}
.bc-icon svg { width: 19px; height: 19px; }
.bc-ic-purple  { background: var(--purple-bg); } .bc-ic-purple svg  { stroke: var(--purple); }
.bc-ic-green   { background: var(--green-bg); }  .bc-ic-green svg   { stroke: #5FA82E; }
.bc-ic-jasmine { background: var(--jasmine-bg); }.bc-ic-jasmine svg { stroke: #B08900; }

/* ── Grid spans (pro bento) ── */
.b-brand, .b-teamx, .b-alerts { grid-column: span 4; }

/* ── Mockup shell ── */
.bc-mock {
  margin-top: 18px; border-radius: 14px; min-height: 150px; height: auto; padding: 18px;
  display: flex; flex-direction: column; justify-content: center;
  border: 1px solid var(--ink-08); position: relative; overflow: hidden;
}
.bcm-tint-purple { background:linear-gradient(150deg,#EDE9FE,#F6F4FF 70%); }
.bcm-tint-green { background:linear-gradient(150deg,#EEFAD5,#F3FBE4 70%); }
.bcm-tint-jasmine { background:linear-gradient(150deg,#FFF8DC,#FFFBEF 70%); }
.b-ai .bc-mock-shot { min-height: 220px; }
.b-ghost .bc-mock-shot,
.b-contract .bc-mock-shot,
.b-report .bc-mock-sha,
.b-cmp .bc-mock-shot,
.b-inventory .bc-mock-shot { min-height: 200px; }
.bc-mock-dark { background: linear-gradient(160deg, #1c1928, #141120); border-color: rgba(255,255,255,.06); }
.bc-mock-shot {
  display: flex;
  align-items: center;
  justify-content: center;
  height: auto;
  min-height: 140px;
  padding: 14px;
  background: linear-gradient(160deg, var(--cream-2), var(--purple-bg));
}
.bc-mock-shot.bc-mock-dark {
  background: linear-gradient(160deg, #1c1928, #141120);
}
.bc-mock-sha {
  height: auto;
  min-height: 0;
  padding: 0;
  background: var(--white);
  display: flex;
  align-items: stretch;
}
.bc-mock-sha img {
  width: 100%;
  height: auto;
  display: block;
  object-fit: cover;
  object-position: bottom center;
}

/* Ghost mode mockup (2 screenshots) */
.bc-mock-ghost {
  min-height: 190px;
}
.bcm-ghost-row {
  display: flex;
  align-items: flex-end;
  justify-content: center;
  gap: 12px;
  flex-wrap: wrap;
  padding: 4px 0;
}

/* AI scan + pins + bars */
.bcm-scan {
  position: absolute; left: 0; right: 0; height: 2px;
  background: linear-gradient(90deg, transparent, var(--purple), transparent);
  box-shadow: 0 0 14px 2px rgba(154,136,253,.55);
  animation: bcmScan 3.2s ease-in-out infinite;
}
@keyframes bcmScan { 0%,100% { top: 12%; } 50% { top: 84%; } }
.bcm-pin {
  position: absolute; width: 20px; height: 20px; border-radius: 50%;
  background: var(--red); color: #fff; font-size: 11px; font-weight: 700;
  font-family: 'Poppins', sans-serif; display: flex; align-items: center; justify-content: center;
  box-shadow: 0 0 0 4px rgba(255,82,82,.22); opacity: 0; animation: bcmPop .5s ease forwards;
}
@keyframes bcmPop { 0% { transform: scale(0); } 70% { transform: scale(1.2); } 100% { transform: scale(1); opacity: 1; } }
.bcm-bars { position: absolute; left: 16px; right: 16px; bottom: 16px; display: flex; flex-direction: column; gap: 7px; }
.bcm-bar { height: 6px; border-radius: 4px; background: rgba(255,255,255,.08); overflow: hidden; }
.bcm-bar i { display: block; height: 100%; border-radius: 4px; animation: bcmGrow 1.6s cubic-bezier(.16,1,.3,1) both; }
@keyframes bcmGrow { from { width: 0 !important; } }

/* Compare split */
.bcm-split { display: flex; gap: 8px; padding: 16px; height: 100%; }
.bcm-ph {
  flex: 1; border-radius: 10px; display: flex; align-items: flex-end; padding: 10px;
  font-family: 'Poppins', sans-serif; font-size: 10px; font-weight: 600;
  letter-spacing: .04em; color: #fff;
}
.bcm-ph-in  { background: linear-gradient(135deg, var(--purple-l), var(--purple)); }
.bcm-ph-out { background: linear-gradient(135deg, #FFC9A8, #FF9A6B); }

/* Signature draw */
.bcm-sig { position: absolute; inset: 0; margin: auto; width: 70%; height: 60%; }
.bcm-sig path {
  stroke: #5FA82E; stroke-width: 2.5; fill: none;
  stroke-dasharray: 200; stroke-dashoffset: 200; animation: bcmDraw 3s ease forwards infinite;
}
@keyframes bcmDraw { 0% { stroke-dashoffset: 200; } 55%,100% { stroke-dashoffset: 0; } }

/* QR */
.bcm-qr {
  position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%);
  width: 60px; height: 60px; border-radius: 8px; background-color: #fff;
  background-image:
    repeating-linear-gradient(0deg, var(--ink) 0 3px, transparent 3px 6px),
    repeating-linear-gradient(90deg, var(--ink) 0 3px, transparent 3px 6px);
}

/* Phone */
.bcm-phone {
  position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%);
  width: 64px; height: 104px; border-radius: 13px; background: var(--white);
  border: 3px solid var(--ink-25); display: flex; flex-direction: column; gap: 5px; padding: 12px 9px;
}
.bcm-phone i { height: 9px; border-radius: 3px; background: var(--ink-08); display: block; }
.bcm-phone i:first-child { background: var(--purple); width: 62%; }

/* Avatars */
.bcm-avatars { display: flex; }
.bcm-av {
  width: 36px; height: 36px; border-radius: 50%; margin-left: -8px;
  display: flex; align-items: center; justify-content: center;
  font-family: 'Poppins', sans-serif; font-weight: 700; font-size: 12px; color: #fff;
  border: 2px solid var(--white);
}
.bcm-av:first-child { margin-left: 0; }

/* mini branded report */
.bcm-rep { background:var(--white); border-radius:12px; overflow:hidden; box-shadow:0 10px 26px rgba(14,14,16,.12); transform:rotate(-1.2deg); }
.bcm-rep-head { background:#1B3A5C; padding:11px 14px; display:flex; align-items:center; justify-content:space-between; }
.bcm-rep-brand { display:flex; align-items:center; gap:8px; }
.bcm-rep-logo { width:22px; height:22px; border-radius:6px; background:var(--white); display:flex; align-items:center; justify-content:center; font-family:'Poppins',sans-serif; font-weight:800; font-size:10px; color:#1B3A5C; }
.bcm-rep-name { font-family:'Poppins',sans-serif; font-weight:700; font-size:11px; color:var(--white); }
.bcm-rep-sub { font-size:7.5px; color:rgba(255,255,255,.55); letter-spacing:.8px; text-transform:uppercase; }
.bcm-rep-type { font-size:7.5px; letter-spacing:1px; text-transform:uppercase; color:rgba(255,255,255,.65); border:1px solid rgba(255,255,255,.25); padding:3px 7px; border-radius:999px; }
.bcm-rep-body { padding:10px 14px; display:flex; flex-direction:column; gap:6px; }
.bcm-rep-line { height:5px; border-radius:3px; background:rgba(14,14,16,.08); }
.bcm-brand-foot { display:flex; align-items:center; gap:8px; margin-top:14px; }
.bcm-sw { width:15px; height:15px; border-radius:5px; background:#1B3A5C; box-shadow:0 0 0 2px rgba(14,14,16,.12); }
.bcm-hex { font-size:10.5px; color:rgba(14,14,16,.4); font-family:monospace; }

/* credit pool */
.bcm-pool { background:var(--white); border-radius:12px; padding:13px 16px; box-shadow:0 8px 22px rgba(14,14,16,.08); margin-top:14px; }
.bcm-pool-head { display:flex; justify-content:space-between; font-size:11px; margin-bottom:8px; }
.bcm-pool-lbl { color:rgba(14,14,16,.6); font-weight:600; }
.bcm-pool-n { font-family:'Poppins',sans-serif; font-weight:800; }
.bcm-pool-bar { height:7px; border-radius:99px; background:rgba(14,14,16,.07); overflow:hidden; }
.bcm-pool-fill { height:100%; width:70%; border-radius:99px; background:linear-gradient(90deg,var(--green),#A8E063); }
.bcm-tint-green .bcm-avatars { justify-content:center; margin-bottom:0; }

/* notifications */
.bcm-notif { background:var(--white); border-radius:14px; padding:12px 14px; box-shadow:0 10px 26px rgba(14,14,16,.1); display:flex; gap:11px; align-items:flex-start; transform:rotate(.8deg); }
.bcm-notif-2 { margin-top:10px; transform:rotate(-.6deg); opacity:.55; scale:.96; }
.bcm-notif-ico { width:32px; height:32px; border-radius:10px; background:var(--jasmine); display:flex; align-items:center; justify-content:center; flex-shrink:0; color:var(--ink); }
.bcm-notif-ico svg { width:16px; height:16px; }
.bcm-notif-ico-ok { background:var(--green); }
.bcm-notif-title { font-family:'Poppins',sans-serif; font-weight:700; font-size:12px; margin-bottom:2px; }
.bcm-notif-sub { font-size:11px; color:rgba(14,14,16,.6); line-height:1.4; }
.bcm-notif-time { font-size:9.5px; color:rgba(14,14,16,.4); margin-left:auto; flex-shrink:0; }

/* ── Responsive ── */
@media (max-width: 1100px) {
  .b-brand, .b-teamx, .b-alerts { grid-column: span 12; }
}
@media (max-width: 768px) {
  .bento { gap: 12px; }
  .b-brand, .b-teamx, .b-alerts { grid-column: span 12; }
  .bento-card { padding: 24px; }
}


/* ══ TITLE VARIANTS — remplacements em purple ══ */

/* Corporate underline — For Pros */
.title-underline {
  display: inline;
  font-style: normal;
  color: inherit;
  border-bottom: 3px solid rgba(255,255,255,.25);
  padding-bottom: 2px;
}

/* Douleur rouge — For Private */
.title-pain {
  display: inline;
  font-style: italic;
  color: rgba(255,82,82,.75);
}

/* Italic blanc pur — How It Works dark */
.title-white-italic {
  display: inline;
  font-style: italic;
  color: rgba(255,255,255,.9);
}

/* Editorial légèrement agrandi — Sample Report */
.title-editorial {
  display: inline;
  font-style: italic;
  color: inherit;
  font-size: 1.08em;
  letter-spacing: -.5px;
}

/* Italic discret — Pricing */
.title-muted-italic {
  display: inline;
  font-style: italic;
  color: var(--ink-60);
}

/* ══ HOW IT WORKS ══ */
.hiw {
  padding: 120px 0;
  background: var(--ink);
  position: relative;
  overflow: hidden;
}
/* Pont haut depuis jasmine/cream */
.hiw-top-bridge {
  position: absolute;
  top: -56px; left: 0; right: 0; height: 56px;
  background: linear-gradient(to bottom, transparent, var(--ink));
  pointer-events: none; z-index: 4;
}
/* Atmosphère purple dans le dark */
.hiw::before {
  content: '';
  position: absolute; inset: 0;
  background:
    radial-gradient(ellipse 70% 50% at 50% 50%, rgba(154,136,253,.07) 0%, transparent 65%),
    radial-gradient(ellipse 40% 40% at 5% 80%, rgba(202,254,135,.04) 0%, transparent 50%),
    radial-gradient(ellipse 35% 35% at 95% 20%, rgba(254,222,128,.03) 0%, transparent 50%);
  pointer-events: none;
}
/* Pont bas vers cream-2 sample */
.hiw::after {
  content: '';
  position: absolute;
  bottom: -56px; left: 0; right: 0; height: 56px;
  background: linear-gradient(to bottom, var(--ink), transparent);
  pointer-events: none; z-index: 4;
}

.hiw-header {
  text-align: center;
  margin-bottom: 72px;
  position: relative; z-index: 2;
}
.hiw-header .section-eyebrow { color: rgba(255,255,255,.45); }
.hiw-header .section-eyebrow::before { background: rgba(255,255,255,.35); }
.hiw-header .section-title { color: var(--white); }
.hiw-header .section-title em { color: var(--purple); }
.hiw-header .section-sub { color: rgba(255,255,255,.45); margin: 0 auto; }

/* Steps grid */
.hiw-grid {
  display: grid;
  grid-template-columns: 1fr 40px 1fr 40px 1fr;
  gap: 0;
  align-items: start;
  position: relative; z-index: 2;
}

/* Connector arrow */
.hiw-arrow {
  display: flex;
  align-items: center;
  justify-content: center;
  padding-top: 28px;
  color: rgba(255,255,255,.15);
}
.hiw-arrow svg { width: 20px; height: 20px; flex-shrink: 0; }

/* Each step card */
.hiw-step {
  position: relative;
  padding: 0 16px;
}


/* Step content */
.hiw-step-inner {
  position: relative; z-index: 1;
  padding-top: 0;
}

/* Mini phone mockup per step */
.hiw-phone {
  width: 100%;
  min-height: 0;
  background: transparent;
  border: none;
  border-radius: 0;
  overflow: visible;
  margin-bottom: 24px;
  position: relative;
  box-shadow: none;
  display: flex;
  justify-content: center;
  padding: 0;
}

/* Step text */
.hiw-step-badge {
  display: inline-flex; align-items: center; gap: 6px;
  font-size: 10px; font-weight: 700;
  text-transform: uppercase; letter-spacing: 2px;
  color: var(--purple);
  margin-bottom: 10px;
}
.hiw-step-badge-dot {
  width: 5px; height: 5px; border-radius: 50%;
  background: var(--purple);
}
.hiw-step h3 {
  font-family: 'Poppins', sans-serif;
  font-weight: 700; font-size: 20px;
  letter-spacing: -.5px; line-height: 1.25;
  color: var(--white); margin-bottom: 10px;
}
.hiw-step p {
  font-size: 14px; color: rgba(255,255,255,.45);
  line-height: 1.7;
}

/* Time badge */
.hiw-time-badge {
  display: inline-flex; align-items: center; gap: 6px;
  margin-top: 14px;
  padding: 5px 12px;
  background: rgba(255,255,255,.05);
  border: 1px solid rgba(255,255,255,.09);
  border-radius: 999px;
  font-size: 11px; font-weight: 600;
  color: rgba(255,255,255,.35);
}
.hiw-time-badge svg { width: 11px; height: 11px; opacity: .6; }

/* Bottom CTA */
.hiw-cta {
  display: flex;
  align-items: center; justify-content: center;
  gap: 20px;
  margin-top: 48px;
  position: relative; z-index: 2;
  flex-wrap: wrap;
}
.hiw-cta-sub {
  font-size: 13px; color: rgba(255,255,255,.35);
}
.hiw-cta-demo {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 14px 22px;
  border-radius: 999px;
  border: 1.5px solid rgba(255,255,255,.18);
  background: transparent;
  color: var(--white);
  font-family: 'Poppins', sans-serif;
  font-weight: 600;
  font-size: 14px;
  cursor: pointer;
  transition: border-color .25s, background .25s, transform .25s;
}
.hiw-cta-demo:hover {
  border-color: var(--purple);
  background: rgba(154,136,253,.12);
  transform: translateY(-2px);
}
.hiw-cta-demo svg { width: 15px; height: 15px; }

/* Interactive Supademo */
.hiw-demo {
  position: relative;
  z-index: 2;
  max-width: 960px;
  margin: 0 auto 56px;
  border-radius: 24px;
  overflow: hidden;
  border: 1px solid rgba(255,255,255,.1);
  background: #16141f;
  box-shadow: 0 28px 80px rgba(0,0,0,.45);
}
.hiw-demo-frame {
  position: relative;
  width: 100%;
  aspect-ratio: 16 / 10;
  background: #0e0e10;
}
.hiw-demo-frame iframe {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  border: 0;
}
.hiw-demo-label {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  padding: 12px 18px;
  background: rgba(255,255,255,.03);
  border-bottom: 1px solid rgba(255,255,255,.06);
}
.hiw-demo-label span {
  font-size: 12px;
  font-weight: 600;
  letter-spacing: .08em;
  text-transform: uppercase;
  color: rgba(255,255,255,.45);
}
.hiw-demo-label button {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  border: none;
  background: transparent;
  color: var(--purple);
  font-family: 'Poppins', sans-serif;
  font-weight: 600;
  font-size: 13px;
  cursor: pointer;
  padding: 0;
}
.hiw-demo-label button:hover { color: var(--white); }

/* Responsive */
@media(max-width: 1100px) {
  .hiw-grid {
    grid-template-columns: 1fr;
    gap: 8px;
  }
  .hiw-arrow { display: none; }
  .hiw-step { padding: 0; }
  .hiw-step-num { font-size: 80px; }
  .hiw-phone { max-width: 320px; }
  .hiw-demo { margin-bottom: 40px; }
}
@media(max-width: 768px) {
  .hiw-cta { flex-direction: column; gap: 12px; text-align: center; align-items: stretch; }
  .hiw-cta .btn-ink,
  .hiw-cta .hiw-cta-demo { width: 100%; justify-content: center; }
  .hiw-demo { border-radius: 18px; }
  .hiw-demo-frame { aspect-ratio: 4 / 5; }
}

/* ══ TESTIMONIALS ══ */
.testi {
  padding: 140px 0;
  background: var(--ink);
  position: relative;
  overflow: hidden;
}
/* Subtle purple glow top + jasmine glow bottom for depth */
.testi::before {
  content: '';
  position: absolute; inset: 0;
  background:
    radial-gradient(ellipse 70% 35% at 50% 0%, rgba(154,136,253,.07) 0%, transparent 50%),
