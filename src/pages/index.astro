.trip-hex { font-size:11px; color:rgba(255,255,255,.4); font-family:monospace; letter-spacing:.3px; }
/* team */
.trip-team { display:flex; flex-direction:column; gap:9px; }
.trip-agent { display:flex; align-items:center; gap:11px; padding:8px 12px; background:rgba(255,255,255,.03); border:1px solid rgba(255,255,255,.05); border-radius:11px; }
.trip-av { width:26px; height:26px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-family:'Poppins',sans-serif; font-weight:700; font-size:9.5px; flex-shrink:0; }
.trip-av-p { background:var(--purple); color:var(--ink); }
