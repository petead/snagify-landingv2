@media(max-width: 1100px) {
  .footer-top { grid-template-columns: 1fr 1fr; }
}
@media(max-width: 768px) {
  footer { padding: 60px 20px 32px; }
  .footer-top { grid-template-columns: 1fr; gap: 36px; }
  .footer-bottom { flex-direction: column; gap: 16px; text-align: center; }
}

/* ══════════════════════════════════
   FAQ
══════════════════════════════════ */
.faq {
  padding: 140px 48px 120px;
  background: var(--cream);
  position: relative;
}
.faq-inner { max-width: 900px; margin: 0 auto; }

.faq-head { margin-bottom: 48px; }
.faq h2 {
  font-family: 'Poppins', sans-serif;
  font-weight: 800;
  font-size: clamp(36px, 5vw, 64px);
  line-height: 1.02;
  letter-spacing: -1.5px;
  margin: 18px 0 20px;
  color: var(--ink);
}
.faq h2 em {
  color: var(--purple);
  font-style: italic;
}
.faq-sub {
  font-size: 17px;
  line-height: 1.55;
  color: var(--ink-60);
  max-width: 560px;
}

.faq-persona {
  display: inline-flex;
  padding: 5px;
  background: var(--ink-08);
  border-radius: 999px;
  margin-bottom: 36px;
  gap: 0;
}
.faq-persona-btn {
  padding: 10px 22px;
  border: none;
  background: transparent;
  color: var(--ink-60);
  font-family: inherit;
  font-size: 13px;
  font-weight: 600;
  border-radius: 999px;
  cursor: pointer;
  transition: all .25s cubic-bezier(.16,1,.3,1);
}
.faq-persona-btn:hover { color: var(--ink); }
.faq-persona-btn.active {
  background: var(--ink);
  color: var(--white);
  font-weight: 700;
}

.faq-persona-panel { display: none; }
.faq-persona-panel.active {
  display: block;
  animation: faqFadeIn .4s cubic-bezier(.16,1,.3,1);
}
@keyframes faqFadeIn {
  from { opacity: 0; transform: translateY(6px); }
  to   { opacity: 1; transform: translateY(0); }
}

.faq-tabs {
  display: flex;
  gap: 8px;
  margin-bottom: 32px;
  flex-wrap: wrap;
}
.faq-tab {
  padding: 10px 18px;
  border-radius: 999px;
  background: transparent;
  color: var(--ink-60);
  border: 1px solid var(--ink-25);
  font-family: inherit;
  font-size: 13px;
  font-weight: 500;
  cursor: pointer;
  transition: all .25s cubic-bezier(.16,1,.3,1);
  display: inline-flex;
  align-items: center;
  gap: 8px;
}
.faq-tab:hover {
  color: var(--ink);
  border-color: var(--ink);
}
.faq-tab.active {
  background: var(--purple);
  color: var(--ink);
  border-color: var(--purple);
  font-weight: 700;
}
.faq-tab-count {
  font-size: 11px;
  opacity: .55;
  font-weight: 700;
}
.faq-tab.active .faq-tab-count { opacity: .7; }

.faq-panel { display: none; }
.faq-panel.active { display: block; animation: faqFadeIn .35s cubic-bezier(.16,1,.3,1); }

.faq-list { border-top: 1px solid var(--ink-25); }
.faq-item { border-bottom: 1px solid var(--ink-25); }
#faq-checkout-cost,
#faq-credits-pro { scroll-margin-top: 96px; }

.faq-q {
  width: 100%;
  background: none;
  border: none;
  padding: 26px 0;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 24px;
  cursor: pointer;
  text-align: left;
  font-family: 'Poppins', sans-serif;
  font-weight: 700;
  font-size: 19px;
  line-height: 1.4;
  color: var(--ink);
  transition: color .25s;
}
.faq-q:hover { color: var(--purple); }

.faq-icon {
  flex-shrink: 0;
  width: 36px;
  height: 36px;
  border-radius: 50%;
  background: transparent;
  border: 1px solid var(--ink-25);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--ink-60);
  font-size: 22px;
  font-weight: 300;
  line-height: 1;
  transition: all .4s cubic-bezier(.16,1,.3,1);
}
.faq-item.open .faq-icon {
  background: var(--purple);
  border-color: var(--purple);
  color: var(--white);
  transform: rotate(45deg);
  font-weight: 500;
}

.faq-a {
  max-height: 0;
  overflow: hidden;
  transition: max-height .5s cubic-bezier(.16,1,.3,1);
}
.faq-a-inner { padding: 0 0 28px; max-width: 680px; }
.faq-a p {
  font-size: 16px;
  line-height: 1.7;
  color: var(--ink-60);
}

.faq-bottom {
  margin-top: 48px;
  padding: 24px 28px;
  background: var(--purple-bg);
  border: 1px solid rgba(154,136,253,.25);
  border-radius: 20px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24px;
  flex-wrap: wrap;
}
.faq-bottom-text h4 {
  font-family: 'Poppins', sans-serif;
  font-weight: 700;
  font-size: 17px;
  color: var(--ink);
  margin: 0 0 4px;
}
.faq-bottom-text p {
  font-size: 14px;
  color: var(--ink-60);
  margin: 0;
}
.faq-bottom-actions { display: flex; gap: 10px; flex-wrap: wrap; }

.faq-btn {
  padding: 12px 20px;
  border-radius: 999px;
  border: none;
  cursor: pointer;
  text-decoration: none;
  font-family: 'DM Sans', sans-serif;
  font-size: 13px;
  font-weight: 700;
  display: inline-flex;
  align-items: center;
  gap: 8px;
  transition: transform .3s cubic-bezier(.16,1,.3,1), box-shadow .3s;
}
.faq-btn:hover { transform: translateY(-2px); }
.faq-btn-wa { background: #25D366; color: var(--white); }
.faq-btn-wa:hover { box-shadow: 0 8px 20px rgba(37,211,102,.3); }
.faq-btn-chat { background: var(--purple); color: var(--ink); }
.faq-btn-chat:hover { box-shadow: 0 8px 20px rgba(154,136,253,.4); }
.faq-btn-mail { background: var(--ink); color: var(--white); }
.faq-btn-mail:hover { box-shadow: 0 8px 20px rgba(14,14,16,.3); }

@media (max-width: 768px) {
  .faq { padding: 80px 20px; }
  .faq h2 { letter-spacing: -1px; }
  .faq-persona { width: 100%; justify-content: stretch; }
  .faq-persona-btn { flex: 1; padding: 10px 16px; font-size: 12px; }
  .faq-q { font-size: 16px; padding: 22px 0; gap: 16px; }
  .faq-icon { width: 30px; height: 30px; font-size: 18px; }
  .faq-a p { font-size: 15px; }
  .faq-bottom { flex-direction: column; align-items: stretch; text-align: center; padding: 20px; }
  .faq-bottom-actions { justify-content: center; }
}

/* ══════════════════════════════════
   ROI CALCULATOR
══════════════════════════════════ */
.roi {
  padding: 140px 48px 120px;
  background: var(--ink);
  color: var(--white);
  position: relative;
  overflow: hidden;
}
.roi-inner { max-width: 1100px; margin: 0 auto; }

.roi-head { text-align: center; max-width: 640px; margin: 0 auto 48px; }
.roi h2 {
  font-family: 'Poppins', sans-serif;
  font-weight: 800;
  font-size: clamp(36px, 5vw, 64px);
  line-height: 1.02;
  letter-spacing: -1.5px;
  margin: 0 0 18px;
  color: var(--white);
}
.roi h2 em { color: var(--purple); font-style: italic; }
.roi-sub {
  font-size: 17px; line-height: 1.55;
  color: rgba(255,255,255,0.55);
  max-width: 560px;
  margin: 0 auto;
}
.roi-sub strong { color: var(--white); font-weight: 600; }

.roi-widget {
  max-width: 1000px; margin: 0 auto;
  background: rgba(22,20,31,.6);
  border: 1px solid rgba(255,255,255,.08);
  border-radius: 28px;
  overflow: hidden;
  display: grid;
  grid-template-columns: 1.15fr 1fr;
  backdrop-filter: blur(12px);
}
.roi-wg-left { padding: 40px 42px; border-right: 1px solid rgba(255,255,255,.08); }
.roi-wg-right {
  padding: 40px 42px;
  background: linear-gradient(160deg, rgba(154,136,253,.09), transparent 60%);
}

.roi-slider-block { margin-bottom: 36px; }
.roi-slider-head {
  display: flex; justify-content: space-between; align-items: baseline;
  margin-bottom: 16px;
  gap: 12px;
}
.roi-slider-label {
  font-size: 13px; font-weight: 600;
  color: rgba(255,255,255,0.6);
  letter-spacing: 0.3px;
  display: inline-flex; align-items: center; gap: 6px;
}
.roi-slider-value {
  font-family: 'Poppins', sans-serif;
  font-size: 36px; font-weight: 800;
  color: var(--white);
  letter-spacing: -1.2px;
  line-height: 1;
}
.roi-slider-value .unit {
  font-size: 14px; font-weight: 500;
  color: rgba(255,255,255,0.5);
  letter-spacing: 0;
  margin-left: 4px;
}

.roi-slider {
  -webkit-appearance: none; appearance: none;
  width: 100%; height: 4px;
  background: rgba(255,255,255,0.1);
  border-radius: 999px;
  outline: none;
  cursor: pointer;
}
.roi-slider::-webkit-slider-thumb {
  -webkit-appearance: none; appearance: none;
  width: 22px; height: 22px;
  background: var(--purple);
  border-radius: 50%;
  cursor: pointer;
  border: 3px solid var(--ink);
  box-shadow: 0 0 0 1px var(--purple);
  transition: transform .2s ease;
}
.roi-slider::-webkit-slider-thumb:hover { transform: scale(1.18); }
.roi-slider::-moz-range-thumb {
  width: 22px; height: 22px;
  background: var(--purple);
  border-radius: 50%;
  cursor: pointer;
  border: 3px solid var(--ink);
  box-shadow: 0 0 0 1px var(--purple);
}
.roi-slider-hint {
  font-size: 12px; color: rgba(255,255,255,0.35);
  margin-top: 10px;
}

.roi-math-toggle {
  font-size: 13px; color: rgba(255,255,255,0.5);
  background: none; border: none;
  cursor: pointer;
  padding: 8px 0;
  margin-top: 4px;
  display: inline-flex; align-items: center; gap: 6px;
  font-family: inherit;
  transition: color .2s;
}
.roi-math-toggle:hover { color: var(--purple); }
.roi-math-toggle .chev {
  display: inline-block;
  transition: transform .25s;
  font-size: 10px;
}
.roi-math-toggle.open .chev { transform: rotate(180deg); }
.roi-math {
  max-height: 0; overflow: hidden;
  transition: max-height .4s cubic-bezier(.16,1,.3,1);
}
.roi-math-inner {
  padding: 14px 16px;
  margin-top: 10px;
  background: rgba(255,255,255,0.04);
  border-radius: 12px;
  border: 1px solid rgba(255,255,255,0.06);
  font-size: 12px; line-height: 1.8;
  color: rgba(255,255,255,0.55);
  font-family: 'JetBrains Mono', 'Space Mono', ui-monospace, monospace;
}
.roi-math-inner strong { color: var(--purple); font-weight: 700; }

.roi-result {
  position: relative;
}

.roi-plan-badge {
  display: inline-block;
  padding: 5px 12px;
  background: rgba(154,136,253,0.18);
  color: var(--purple);
  border-radius: 999px;
  font-size: 11px; font-weight: 800;
  letter-spacing: 0.6px; text-transform: uppercase;
  margin-bottom: 10px;
  position: relative;
}
.roi-result-label {
  font-size: 11px; font-weight: 700;
  color: rgba(255,255,255,0.5);
  letter-spacing: 1.4px; text-transform: uppercase;
  margin: 0 0 14px;
  position: relative;
}
.roi-big {
  font-family: 'Poppins', sans-serif;
  font-weight: 800;
  font-size: clamp(48px, 6vw, 72px);
  line-height: 1;
  letter-spacing: -3px;
  color: var(--white);
  margin: 0 0 8px;
  position: relative;
}
.roi-big .aed {
  font-size: 0.42em;
  color: rgba(255,255,255,0.5);
  margin-right: 8px;
  vertical-align: 10%;
  font-weight: 700;
  letter-spacing: -1px;
}
.roi-big-sub {
  font-size: 14px;
  color: rgba(255,255,255,0.5);
  margin: 0 0 26px;
  position: relative;
}

.roi-break {
  padding-top: 18px;
  border-top: 1px solid rgba(255,255,255,0.08);
  position: relative;
}
.roi-line {
  display: flex; justify-content: space-between; align-items: center;
  padding: 9px 0;
  font-size: 14px;
}
.roi-line-label {
  color: rgba(255,255,255,0.65);
  display: inline-flex; align-items: center; gap: 10px;
}
.roi-line-val {
  font-weight: 700; color: var(--white);
  font-family: 'Poppins', sans-serif;
  letter-spacing: -0.3px;
}
.roi-line.plus .roi-line-val { color: var(--purple); }
.roi-line.minus .roi-line-val { color: rgba(255,255,255,0.75); }
.roi-tick, .roi-minus {
  width: 16px; height: 16px; border-radius: 50%;
  display: inline-flex; align-items: center; justify-content: center;
  font-size: 10px; font-weight: 900;
  flex-shrink: 0;
}
.roi-tick { background: rgba(154,136,253,0.2); color: var(--purple); }
.roi-minus { background: rgba(255,255,255,0.08); color: rgba(255,255,255,0.55); font-weight: 700; line-height: 1; }

.roi-multiplier {
  display: flex; align-items: center; gap: 14px;
  margin: 22px 0 0;
  padding: 14px 16px;
  background: rgba(154,136,253,0.08);
  border: 1px solid rgba(154,136,253,0.22);
  border-radius: 14px;
  position: relative;
}
.roi-multi-num {
  font-family: 'Poppins', sans-serif;
  font-size: 26px; font-weight: 800;
  color: var(--purple);
  letter-spacing: -1px;
  flex-shrink: 0;
}
.roi-multi-text {
  font-size: 13px;
  color: rgba(255,255,255,0.75);
  line-height: 1.45;
}

.roi-cta {
  display: flex; align-items: center; justify-content: center; gap: 8px;
  width: 100%;
  margin-top: 20px;
  padding: 16px 22px;
  background: var(--purple);
  color: var(--ink);
  text-decoration: none;
  border: none; border-radius: 999px;
  font-family: 'Poppins', sans-serif;
  font-size: 14px; font-weight: 800;
  cursor: pointer;
  transition: transform .3s cubic-bezier(.16,1,.3,1), box-shadow .3s;
  position: relative;
}
.roi-cta:hover {
  transform: translateY(-2px);
  box-shadow: 0 14px 40px rgba(154,136,253,0.35);
}

@media (max-width: 960px) {
  .roi-widget { grid-template-columns: 1fr; }
  .roi-wg-left { border-right: none; border-bottom: 1px solid rgba(255,255,255,.08); }
}
@media (max-width: 768px) {
  .roi { display: none !important; }
}

/* ══════════════════════════════════
   TESTIMONIAL AUTHOR + AVATAR
══════════════════════════════════ */
.testi-author {
  display: flex;
  align-items: center;
  gap: 12px;
  border-top: 1px solid rgba(14,14,16,0.08);
  padding-top: 18px;
  margin-top: 24px;
}
.testi-avatar {
  flex-shrink: 0;
  width: 48px;
  height: 48px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: 'Poppins', sans-serif;
  font-weight: 800;
  font-size: 16px;
  letter-spacing: -0.5px;
  line-height: 1;
}
.testi-avatar.is-pro {
  background: var(--purple);
  color: var(--white);
}
.testi-avatar.is-landlord {
  background: var(--jasmine);
  color: var(--ink);
}
.testi-author-text {
  flex: 1;
  min-width: 0;
}
.testi-author h4 {
  font-family: 'Poppins', sans-serif;
  font-weight: 700;
  font-size: 14px;
  color: var(--ink);
  margin: 0 0 2px;
  line-height: 1.2;
}
.testi-author p {
  font-size: 12px;
  color: var(--ink-60);
  margin: 0;
  line-height: 1.4;
}
/* Dark testimonial cards: keep contrast on ink-tinted UI */
.testi .testi-author {
  border-top-color: rgba(255,255,255,0.1);
}
.testi .testi-author h4 {
  color: var(--white);
}
.testi .testi-author p {
  color: rgba(255,255,255,0.55);
}

/* ══════════════════════════════════
   SCROLL REVEALS
══════════════════════════════════ */
.reveal { opacity: 0; transform: translateY(24px); transition: opacity .75s cubic-bezier(.16,1,.3,1), transform .75s cubic-bezier(.16,1,.3,1); }
.reveal.in { opacity: 1; transform: translateY(0); }
.reveal-delay-1 { transition-delay: .12s; }
.reveal-delay-2 { transition-delay: .22s; }
.reveal-delay-3 { transition-delay: .34s; }

/* ══ PAIN FINANCIÈRE ══ */
.pain-section {
  padding: 140px 0 160px;
  background: var(--ink);
  position: relative;
  overflow: hidden;
}
/* Top bridge : purple marquee → ink */
.pain-section-bridge {
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 60px;
  background: linear-gradient(to bottom, rgba(154,136,253,.06), transparent);
  pointer-events: none;
  z-index: 2;
}

/* Fond dramatique : rouge glow + grain */
.pain-section::before {
  content: '';
  position: absolute; inset: 0;
  z-index: 0;
  background:
    radial-gradient(ellipse 60% 50% at 30% 50%, rgba(255,82,82,.07) 0%, transparent 60%),
    radial-gradient(ellipse 50% 60% at 75% 40%, rgba(154,136,253,.06) 0%, transparent 55%),
    radial-gradient(ellipse 80% 30% at 50% 100%, rgba(255,82,82,.04) 0%, transparent 60%);
  pointer-events: none;
}

/* Ligne décorative horizontale centrale */
.pain-section::after {
  content: '';
  position: absolute;
  left: 0; right: 0;
  top: 50%;
  height: 1px;
  z-index: 1;
  background: linear-gradient(90deg, transparent 0%, rgba(255,82,82,.08) 20%, rgba(255,82,82,.15) 50%, rgba(255,82,82,.08) 80%, transparent 100%);
  pointer-events: none;
}

.pain-inner {
  position: relative;
  z-index: 1;
  max-width: 900px;
  margin: 0 auto;
  padding: 0 48px;
  text-align: center;
}

/* Top : chiffre centré seul — il respire */
.pain-top {
  text-align: center;
  padding-bottom: 48px;
  margin-bottom: 48px;
  border-bottom: 1px solid rgba(255,255,255,.08);
}

.pain-big-label {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-size: 11px;
  text-transform: uppercase;
  letter-spacing: 3.5px;
  color: rgba(255,255,255,.3);
  font-weight: 500;
  margin-bottom: 24px;
}
.pain-big-label::before,
.pain-big-label::after {
  content: '';
  display: block;
  width: 32px;
  height: 1px;
  background: rgba(255,255,255,.15);
}

/* Le chiffre — le vrai star */
.pain-big-num {
  font-family: 'Poppins', sans-serif;
  font-weight: 800;
  font-size: clamp(72px, 10vw, 140px);
  letter-spacing: -6px;
  line-height: .9;
  color: var(--white);
  margin-bottom: 20px;
  text-shadow:
    0 0 60px rgba(255,82,82,.25),
    0 0 120px rgba(255,82,82,.12),
    0 0 200px rgba(255,82,82,.06);
  position: relative;
  display: inline-block;
}

/* Soulignement rouge sous le chiffre */
.pain-big-num::after {
  content: '';
  position: absolute;
  bottom: -8px; left: 50%;
  transform: translateX(-50%);
  width: 60%;
  height: 3px;
  background: linear-gradient(90deg, transparent, var(--red), transparent);
  border-radius: 2px;
  opacity: .5;
}

.pain-big-sub {
  font-size: 18px;
  color: rgba(255,255,255,.4);
  line-height: 1.5;
  max-width: 520px;
  margin-left: auto;
  margin-right: auto;
  font-style: italic;
}

.pain-bottom {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}
.pain-headline {
  font-family: 'Poppins', sans-serif;
  font-weight: 700;
  font-size: clamp(24px, 3vw, 34px);
  line-height: 1.3;
  letter-spacing: -.6px;
  color: var(--white);
  max-width: 720px;
  margin: 0 auto;
}
.pain-headline strong { color: #FF8A65; font-weight: 700; }

@media(max-width: 768px) {
  .pain-section { padding: 100px 0 120px; }
  .pain-inner { padding: 0 20px; }
  .pain-top { padding-bottom: 40px; margin-bottom: 40px; }
}
@media (max-width: 480px) {
  .pain-headline br { display: none; }
}

/* Bouton primaire sur fond dark */
.btn-pros-primary {
  display: inline-flex; align-items: center; gap: 10px;
  padding: 15px 30px;
  background: var(--white);
  color: var(--ink);
  font-family: 'Poppins', sans-serif; font-weight: 700; font-size: 15px;
  border-radius: 999px; text-decoration: none; border: none; cursor: pointer;
  transition: background .3s, transform .35s cubic-bezier(.16,1,.3,1), box-shadow .35s;
}
.btn-pros-primary:hover {
  background: var(--purple);
  color: var(--ink);
  transform: translateY(-4px);
  box-shadow: 0 16px 40px rgba(154,136,253,.4);
}

/* ══ FOR PROS ══ */
.for-pros {
  padding: 0;
  background: var(--ink);
  position: relative;
  overflow: hidden;
}
/* Atmosphère corporate — grille subtile + purple glow */
.for-pros::before {
  content: '';
  position: absolute; inset: 0;
  background:
    radial-gradient(ellipse 60% 50% at 80% 40%, rgba(154,136,253,.09) 0%, transparent 60%),
    radial-gradient(ellipse 40% 40% at 10% 70%, rgba(202,254,135,.04) 0%, transparent 55%);
  pointer-events: none;
}
/* Dot grid subtil en fond */
.for-pros::after {
  content: '';
  position: absolute; inset: 0;
  background-image: radial-gradient(circle, rgba(255,255,255,.04) 1px, transparent 1px);
  background-size: 28px 28px;
  mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 20%, transparent 80%);
  pointer-events: none;
}

/* Starfield / glitter — subtle twinkle behind content */
.pros-stars {
  position: absolute;
  inset: 0;
  z-index: 1;
  pointer-events: none;
  overflow: hidden;
}
.pros-stars::before,
.pros-stars::after {
  content: '';
  position: absolute;
  top: 0; left: 0;
