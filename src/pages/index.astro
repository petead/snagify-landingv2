<script>
// ── SVG INK FILTER (injecté dynamiquement) ──
(function() {
  const svgDefs = document.createElementNS('http://www.w3.org/2000/svg','svg');
  svgDefs.setAttribute('width','0'); svgDefs.setAttribute('height','0');
  svgDefs.style.cssText='position:absolute;pointer-events:none';
  svgDefs.innerHTML = `<defs>
    <filter id="ink-filter" x="-5%" y="-5%" width="110%" height="110%">
      <feTurbulence type="fractalNoise" baseFrequency="0.65" numOctaves="3" stitchTiles="stitch" result="noise"/>
      <feDisplacementMap in="SourceGraphic" in2="noise" scale="1.0" xChannelSelector="R" yChannelSelector="G"/>
    </filter>
  </defs>`;
  document.body.prepend(svgDefs);
})();

// ── SIGNATURE SCROLL TRIGGERS ──
function triggerSigOnScroll(pathId) {
  const path = document.getElementById(pathId);
  if (!path) return;
  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        path.classList.remove('sig-animate');
        void path.getBoundingClientRect();
        path.classList.add('sig-animate');
        obs.unobserve(e.target);
      }
    });
  }, { threshold: 0.55 });
  obs.observe(path.closest('.b-sig-canvas') || path.closest('.hiw-phone') || path);
}

// ── CURSOR (desktop uniquement) ──
const cur = document.getElementById('cur');
const isTouch = window.matchMedia('(max-width: 1024px)').matches || ('ontouchstart' in window);
if (isTouch && cur) cur.style.display = 'none';

if (!isTouch && cur) {
  /**
   * Remonte les ancêtres d'un élément et retourne la première
   * backgroundColor non-transparente trouvée (format rgb/rgba).
   */
  function getEffectiveBg(el) {
    let node = el;
    while (node && node !== document.documentElement) {
      const bg = window.getComputedStyle(node).backgroundColor;
      if (bg && bg !== 'rgba(0, 0, 0, 0)' && bg !== 'transparent') return bg;
      node = node.parentElement;
    }
    return 'rgb(243,241,235)'; // fallback cream
  }

  /**
   * Calcule la luminance relative d'une couleur rgb/rgba.
   * Retourne true si le fond est sombre (luminance < 0.18).
   */
  function isDarkBg(cssColor) {
    const m = cssColor.match(/[\d.]+/g);
    if (!m || m.length < 3) return false;
    const [r, g, b] = [+m[0], +m[1], +m[2]].map(v => {
      v /= 255;
      return v <= 0.03928 ? v / 12.92 : Math.pow((v + 0.055) / 1.055, 2.4);
    });
    const L = 0.2126 * r + 0.7152 * g + 0.0722 * b;
    return L < 0.18;
  }

  let lastDark = false;

  window.addEventListener('mousemove', e => {
    cur.style.left = e.clientX + 'px';
    cur.style.top  = e.clientY + 'px';

    const el = document.elementFromPoint(e.clientX, e.clientY);
    if (el) {
      const bg = getEffectiveBg(el);
      const dark = isDarkBg(bg);
      if (dark !== lastDark) {
        cur.classList.toggle('light', dark);
        lastDark = dark;
      }
    }
  }, { passive: true });

  document.querySelectorAll('a, button').forEach(el => {
    el.addEventListener('mouseenter', () => cur.classList.add('big'));
    el.addEventListener('mouseleave', () => cur.classList.remove('big'));
  });
}

// ── SCROLL PROGRESS + NAV PILL ──
const prog = document.getElementById('prog');
const navEl = document.getElementById('nav');

window.addEventListener('scroll', () => {
  const scrolled = window.scrollY > 60;
  prog.style.width = (window.scrollY / (document.body.scrollHeight - innerHeight) * 100) + '%';

  if (scrolled && !navEl.classList.contains('scrolled')) {
    navEl.classList.add('scrolled');
  } else if (!scrolled && navEl.classList.contains('scrolled')) {
    navEl.classList.remove('scrolled');
  }
}, { passive: true });

// ── REVEAL ON SCROLL ──
const io = new IntersectionObserver(entries => {
  entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('in'); });
}, { threshold: .12 });
document.querySelectorAll('.reveal').forEach(r => io.observe(r));

// ── ANIMATED COUNTER ──
const ctr = document.getElementById('ctr');
let counted = false;
new IntersectionObserver(entries => {
  if (entries[0].isIntersecting && !counted) {
    counted = true;
    let n = 0;
    const end = 2400;
    const step = () => {
      n = Math.min(n + 48, end);
      ctr.textContent = n.toLocaleString() + '+';
      if (n < end) requestAnimationFrame(step);
    };
    requestAnimationFrame(step);
  }
}, { threshold: 1 }).observe(ctr);

// ── SMOOTH ANCHOR ──
function scrollToPricingCards(audience) {
  const grid = document.querySelector(audience === 'pro' ? '#panel-pro .pricing-grid' : '#panel-private .pricing-grid');
  if (!grid) return;
  requestAnimationFrame(() => {
    setTimeout(() => {
      const rect = grid.getBoundingClientRect();
      const top = window.scrollY + rect.top - (window.innerHeight - rect.height) / 2;
      window.scrollTo({ top: Math.max(0, top), behavior: 'smooth' });
    }, 100);
  });
}

document.querySelectorAll('a[href^="#"]').forEach(a => {
  a.addEventListener('click', e => {
    const href = a.getAttribute('href');
    const t = document.querySelector(href);
    if (t) {
      e.preventDefault();
      if (href === '#pricing-particulier' && typeof switchPricing === 'function') {
        switchPricing('private');
        scrollToPricingCards('private');
        return;
      }
      if (href === '#pricing-pro' && typeof switchPricing === 'function') {
        switchPricing('pro');
        if (typeof setBilling === 'function') setBilling('annual');
        scrollToPricingCards('pro');
        return;
      }
      setTimeout(() => t.scrollIntoView({ behavior: 'smooth', block: 'start' }), 50);
    }
  });
});

// ── HAMBURGER MENU ──
(function() {
  function initHamburgerMenu() {
    var burger = document.getElementById('nav-burger');
    var drawer = document.getElementById('nav-drawer');
    var closeBtn = document.getElementById('drawer-close');
    if (!burger || !drawer) return;

    function open() {
      drawer.classList.add('is-open');
      drawer.setAttribute('aria-hidden', 'false');
      drawer.removeAttribute('inert');
      drawer.style.opacity = '1';
      drawer.style.visibility = 'visible';
      burger.classList.add('is-open');
      burger.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
    }
    function close() {
      drawer.classList.remove('is-open');
      drawer.setAttribute('aria-hidden', 'true');
      drawer.setAttribute('inert', '');
      drawer.style.opacity = '0';
      drawer.style.visibility = 'hidden';
      burger.classList.remove('is-open');
      burger.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    }

    burger.addEventListener('click', function(e) {
      e.stopPropagation();
      drawer.style.opacity === '1' ? close() : open();
    });
    if (closeBtn) closeBtn.addEventListener('click', close);
    drawer.querySelectorAll('a').forEach(function(a) {
      a.addEventListener('click', close);
    });
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') close();
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initHamburgerMenu);
  } else {
    initHamburgerMenu();
  }
})();

// ── BILLING + PRICING TOGGLES (exposed on window for inline onclick deep links; Astro bundles scripts as modules) ──
let billingMode = 'annual';

function toggleBilling() {
  setBilling(billingMode === 'monthly' ? 'annual' : 'monthly');
}

function setBilling(mode) {
  billingMode = mode;
  const btnM = document.getElementById('btn-monthly');
  const btnA = document.getElementById('btn-annual');
  const panel = document.getElementById('panel-pro');
  const billingTrack = document.getElementById('billing-pill-track');
  if (billingTrack) billingTrack.dataset.billing = mode;
  if (!btnM || !btnA || !panel) return;
  const isAnnual = mode === 'annual';
  btnM.classList.toggle('active', !isAnnual);
  btnA.classList.toggle('active', isAnnual);
  btnM.setAttribute('aria-selected', String(!isAnnual));
  btnA.setAttribute('aria-selected', String(isAnnual));
  panel.classList.toggle('billing-annual', isAnnual);
}

function showBillingToggle(show) {
  const wrap = document.getElementById('billing-toggle-wrap');
  if (wrap) wrap.classList.toggle('is-visible', show);
  const sub = document.getElementById('pricing-individual-sub');
  if (sub) sub.classList.toggle('is-visible', !show);
}

function updatePricingTitle(type) {
  const title = document.getElementById('pricing-dynamic-title');
  if (!title) return;
  if (type === 'private') {
    title.innerHTML = 'Pay only for <span class="title-muted-italic">check-outs.</span>';
  } else {
    title.innerHTML = 'Plans that <span class="title-muted-italic">pay for themselves.</span>';
  }
}

function syncPricingGliders() {
  const audienceTrack = document.getElementById('pricing-audience-track');
  const billingTrack = document.getElementById('billing-pill-track');
  if (audienceTrack) {
    const active = audienceTrack.dataset.active;
    audienceTrack.dataset.active = '';
    void audienceTrack.offsetWidth;
    audienceTrack.dataset.active = active;
  }
  if (billingTrack) {
    const billing = billingTrack.dataset.billing;
    billingTrack.dataset.billing = '';
    void billingTrack.offsetWidth;
    billingTrack.dataset.billing = billing;
  }
}

function switchPricing(type) {
  const panelPro = document.getElementById('panel-pro');
  const panelPrivate = document.getElementById('panel-private');
  const togglePro = document.getElementById('toggle-pro');
  const togglePrivate = document.getElementById('toggle-private');
  const audienceTrack = document.getElementById('pricing-audience-track');
  if (panelPro) panelPro.classList.toggle('hidden', type !== 'pro');
  if (panelPrivate) panelPrivate.classList.toggle('hidden', type !== 'private');
  if (togglePro) {
    togglePro.classList.toggle('active', type === 'pro');
    togglePro.setAttribute('aria-selected', String(type === 'pro'));
  }
  if (togglePrivate) {
    togglePrivate.classList.toggle('active', type === 'private');
    togglePrivate.setAttribute('aria-selected', String(type === 'private'));
  }
  if (audienceTrack) audienceTrack.dataset.active = type;
  updatePricingTitle(type);
  showBillingToggle(type === 'pro');
  requestAnimationFrame(syncPricingGliders);
}

function initPricingTabs() {
  const pro = document.getElementById('toggle-pro');
  const priv = document.getElementById('toggle-private');
  const m = document.getElementById('btn-monthly');
  const a = document.getElementById('btn-annual');
  if (pro) pro.addEventListener('click', () => switchPricing('pro'));
  if (priv) priv.addEventListener('click', () => switchPricing('private'));
  if (m) m.addEventListener('click', (e) => { e.preventDefault(); setBilling('monthly'); });
  if (a) a.addEventListener('click', (e) => { e.preventDefault(); setBilling('annual'); });
}

initPricingTabs();

switchPricing('private');
setBilling('annual');

window.addEventListener('resize', syncPricingGliders);

const hash = window.location.hash;
if (hash === '#pricing-particulier') {
  switchPricing('private');
  scrollToPricingCards('private');
}
if (hash === '#pricing-pro') {
  switchPricing('pro');
  setBilling('annual');
  scrollToPricingCards('pro');
}

window.switchPricing = switchPricing;
window.setBilling = setBilling;
window.toggleBilling = toggleBilling;
</script>
