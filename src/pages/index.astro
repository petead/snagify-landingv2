/* ══ PRICING ══ */
.pricing {
  padding: 120px 0;
  background: var(--white);
  position: relative;
  border-top: 1px solid var(--ink-25);
}
.pricing::before {
  content: '';
  position: absolute; inset: 0;
  background: radial-gradient(ellipse 55% 45% at 50% 0%, rgba(154,136,253,.04) 0%, transparent 55%);
  pointer-events: none;
  z-index: 0;
}
.pricing .section-wrap { position: relative; z-index: 1; }
.pricing .section-header { margin-bottom: 24px; }

/* ── Toggle audience Landlords / Professionals ── */
.pricing-toggle {
  display: flex; align-items: center; justify-content: center;
  gap: 4px;
  background: var(--white);
  border: 1px solid var(--ink-25);
  border-radius: 999px;
  padding: 5px;
  width: fit-content;
  margin: 0 auto 20px;
}
.ptoggle-btn {
  display: inline-flex; align-items: center; gap: 7px;
  padding: 10px 22px;
  border-radius: 999px; border: none;
  font-family: 'Poppins', sans-serif;
  font-weight: 700; font-size: 13px;
  cursor: pointer;
  background: transparent; color: var(--ink-60);
  transition: color 0.28s ease, transform 0.2s ease;
}
.ptoggle-btn svg {
  width: 17px;
  height: 17px;
  flex-shrink: 0;
  opacity: .5;
  transition: opacity .3s;
}
#toggle-pro svg {
  width: 20px;
  height: 20px;
}
.ptoggle-btn.active svg { opacity: 1; }
.ptoggle-btn:focus-visible {
  outline: 2px solid var(--purple);
  outline-offset: 2px;
}

.pricing-toggle-seg { position: relative; }
.pricing-toggle-glider {
  position: absolute;
  top: 5px; bottom: 5px; left: 5px;
  width: calc((100% - 14px) / 2);
  background: var(--ink);
  border-radius: 999px;
  z-index: 0;
  transition: transform 0.38s cubic-bezier(0.22, 1, 0.36, 1);
  pointer-events: none;
  will-change: transform;
}
.pricing-toggle-seg[data-active="private"] .pricing-toggle-glider { transform: translateX(0); }
.pricing-toggle-seg[data-active="pro"] .pricing-toggle-glider { transform: translateX(calc(100% + 4px)); }
.pricing-toggle-seg .ptoggle-btn {
  position: relative; z-index: 1;
  flex: 1; min-width: 0; justify-content: center;
  background: transparent !important;
}
.pricing-toggle-seg .ptoggle-btn.active { background: transparent !important; color: var(--white); }
.pricing-toggle-seg .ptoggle-btn:not(.active) { color: var(--ink-60); }
.pricing-toggle-seg .ptoggle-btn:active { transform: scale(0.985); }

/* ── Toggle billing Monthly / Annual ── */
.billing-toggle-wrap {
  display: none;
  align-items: center; justify-content: center;
  margin: 0;
  height: 0;
  overflow: hidden;
}
.billing-toggle-wrap.is-visible {
  display: flex;
  margin-top: -6px;
  margin-bottom: 28px;
  height: auto;
  overflow: visible;
}
.pricing-audience-sub {
  display: none;
  text-align: center;
  font-size: 14px;
  font-weight: 500;
  color: var(--ink-60);
  margin: -6px auto 28px;
  line-height: 1.4;
}
.pricing-audience-sub.is-visible {
  display: block;
}
.billing-pill-toggle {
  display: flex; align-items: stretch; gap: 4px;
  background: var(--white);
  border: 1px solid var(--ink-25);
  border-radius: 999px;
  padding: 5px;
}
.billing-pill-btn {
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  padding: 10px 28px;
  border-radius: 999px; border: none;
  font-family: 'Poppins', sans-serif;
  font-weight: 700; font-size: 13px;
  cursor: pointer;
  background: transparent; color: var(--ink-60);
  transition: color 0.28s ease, transform 0.2s ease;
  gap: 2px; line-height: 1.3; min-height: 48px;
}
.billing-pill-btn .billing-pill-sub {
  font-size: 10px; font-weight: 600;
  color: var(--purple);
  font-family: 'DM Sans', sans-serif;
  letter-spacing: .3px;
}
.billing-pill-btn:focus-visible {
  outline: 2px solid var(--purple);
  outline-offset: 2px;
}
.billing-pill-seg { position: relative; }
.billing-pill-glider {
  position: absolute;
  top: 5px; bottom: 5px; left: 5px;
  width: calc((100% - 14px) / 2);
  background: var(--ink);
  border-radius: 999px;
  z-index: 0;
  transition: transform 0.38s cubic-bezier(0.22, 1, 0.36, 1);
  pointer-events: none;
  will-change: transform;
}
.billing-pill-seg[data-billing="annual"] .billing-pill-glider { transform: translateX(calc(100% + 4px)); }
.billing-pill-seg[data-billing="monthly"] .billing-pill-glider { transform: translateX(0); }
.billing-pill-seg .billing-pill-btn {
  position: relative; z-index: 1;
  flex: 1; min-width: 0;
  background: transparent !important;
}
.billing-pill-seg .billing-pill-btn.active { background: transparent !important; color: var(--white); }
.billing-pill-seg .billing-pill-btn:not(.active) { color: var(--ink-60); }
.billing-pill-seg .billing-pill-btn:not(.active) .billing-pill-sub { opacity: .55; }
.billing-pill-seg .billing-pill-btn.active .billing-pill-sub { color: var(--purple-l); }
.billing-pill-seg .billing-pill-btn:active { transform: scale(0.985); }

.pricing-panel { display: block; }
.pricing-panel.hidden { display: none; }

.pricing-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16px;
  margin-bottom: 20px;
  align-items: stretch;
}

.price-card {
  background: var(--white);
  border: 1px solid var(--ink-25);
  border-radius: 24px;
  padding: 36px;
  position: relative;
  transition: transform .4s, box-shadow .4s;
  display: flex;
  flex-direction: column;
  overflow: visible;
  height: 100%;
}
.price-card:hover { transform: translateY(-4px); box-shadow: 0 16px 40px rgba(14,14,16,.08); }

.price-card-popular {
  border: 2px solid var(--purple);
  box-shadow: 0 0 0 4px var(--purple-bg), 0 16px 48px rgba(154,136,253,.18);
  overflow: visible;
}

.price-corner {
  position: absolute;
  top: 14px;
  right: 14px;
  font-family: 'Poppins', sans-serif;
  font-size: 9px;
  font-weight: 700;
  letter-spacing: .7px;
  text-transform: uppercase;
  padding: 5px 11px;
  border-radius: 20px;
  background: var(--purple);
  color: var(--white);
  box-shadow: 0 6px 14px -6px rgba(154,136,253,.7);
  z-index: 2;
  pointer-events: none;
  white-space: nowrap;
}

.price-plan {
  font-size: 11px; text-transform: uppercase; letter-spacing: 2.5px;
  font-weight: 600; color: var(--ink-60);
}
.price-name {
  min-height: 18px;
  padding-right: 96px;
  margin-bottom: 12px;
}
.price-top {
  min-height: 54px;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  margin-bottom: 16px;
}
.price-top-row {
  display: flex;
  align-items: baseline;
  flex-wrap: wrap;
  gap: 10px;
}
.price-save {
  font-family: 'Poppins', sans-serif;
  font-size: 14px;
  font-weight: 700;
  color: var(--purple);
  line-height: 1.2;
  letter-spacing: 0;
}
#panel-pro .price-top {
  min-height: 72px;
  justify-content: flex-start;
  gap: 2px;
}
.price-num {
  font-family: 'Poppins', sans-serif; font-weight: 800;
  font-size: 48px; letter-spacing: -3px;
  line-height: 1; margin-bottom: 0;
}
.price-num .price-suffix { font-size: 15px; font-weight: 400; letter-spacing: 0; color: var(--ink-60); }
.price-num .price-monthly { display: inline; }
.price-num .price-annual  { display: none; }
.billing-annual .price-num .price-monthly { display: none; }
.billing-annual .price-num .price-annual  { display: inline; }

.price-billed { min-height: 15px; }
.price-top .price-billed { margin-top: 4px; margin-bottom: 0; }
.price-annual-sub {
  font-size: 12px; color: var(--ink-60);
  line-height: 1.4;
  min-height: 15px;
  visibility: hidden;
}
.billing-annual .price-annual-sub { visibility: visible; }
.price-annual-sub strong { color: var(--purple); font-weight: 700; }

.metric {
  margin-bottom: 20px;
  background: var(--cream);
  border: 1px solid var(--ink-25);
  border-radius: 14px;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}
.price-card-popular .metric {
  background: var(--purple-bg);
  border-color: rgba(154,136,253,.3);
}
.metric.solo .m-row {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 14px 18px 8px;
  text-align: center;
}
.m-credits {
  font-family: 'Poppins', sans-serif;
  font-weight: 800;
  font-size: 22px;
  letter-spacing: -0.5px;
  color: var(--ink);
  line-height: 1.1;
  text-align: center;
}
.price-card-popular .m-credits { color: var(--purple); }

.metric.duo .duo-row {
  display: flex;
  width: 100%;
}
.metric.duo .m-cell {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 14px 8px;
  gap: 3px;
  position: relative;
}
.metric.duo .m-cell + .m-cell::before {
  content: '';
  position: absolute; left: 0; top: 20%; bottom: 20%;
  width: 1px;
  background: var(--ink-25);
}
.metric .price-faq-link.metric-faq {
  margin-bottom: 0;
  padding: 4px 14px 12px;
  width: 100%;
  font-size: 11px;
  align-self: stretch;
  justify-content: center;
  text-align: center;
}
.m-val {
  font-family: 'Poppins', sans-serif;
  font-weight: 800; font-size: 22px;
  letter-spacing: -1px; line-height: 1;
  color: var(--ink);
}
.price-card-popular .m-val { color: var(--purple); }
.m-lbl {
  font-size: 10px; font-weight: 600;
  text-transform: uppercase; letter-spacing: .8px;
  color: var(--ink-60);
}

.price-extra {
  font-size: 13px;
  color: var(--ink-60);
  margin-bottom: 16px;
  padding: 9px 14px;
  background: var(--cream);
  border-radius: 10px;
}
.price-extra strong { color: var(--ink); font-weight: 700; }

.price-feats {
  list-style: none;
  display: flex; flex-direction: column;
  gap: 10px;
  margin-bottom: 16px;
}
.price-feats li {
  display: flex; align-items: flex-start; gap: 10px;
  font-size: 14px; color: var(--ink-60);
  line-height: 1.4;
}
.price-feats li::before {
  content: '✓';
  color: var(--purple);
  font-weight: 700;
  font-size: 12px;
  flex-shrink: 0;
  margin-top: 2px;
}
.price-feat-highlight {
  color: var(--ink) !important;
  font-weight: 600;
}
.price-includes-line {
  font-family: 'Poppins', sans-serif;
  font-size: 15px;
  font-weight: 600;
  color: var(--ink);
  margin-bottom: 12px;
  line-height: 1.3;
}
.price-includes-plus {
  font-size: 22px;
  font-weight: 800;
  color: var(--purple);
  line-height: 1;
  vertical-align: -2px;
}

.price-faq-link {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: 12px;
  font-weight: 600;
  color: var(--purple);
  text-decoration: none;
  margin-bottom: 16px;
  align-self: flex-start;
}
.price-faq-link svg { flex-shrink: 0; opacity: .75; }
.price-faq-link:hover { text-decoration: underline; }
.price-faq-link:focus-visible {
  outline: 2px solid var(--purple);
  outline-offset: 2px;
  border-radius: 4px;
}

.price-card-spacer { flex: 1; min-height: 0; }

.price-btn {
  display: block; width: 100%; padding: 14px;
  border-radius: 12px; font-family: 'Poppins', sans-serif;
  font-weight: 700; font-size: 14px;
  text-align: center; text-decoration: none;
  cursor: pointer; border: none; transition: all .3s;
  margin-top: 0;
}
.price-btn:focus-visible {
  outline: 2px solid var(--purple);
  outline-offset: 2px;
}
.price-btn-outline {
  background: transparent;
  border: 1.5px solid var(--ink-25);
  color: var(--ink);
}
.price-btn-outline:hover { border-color: var(--ink); background: var(--cream); }
.price-btn-purple { background: var(--purple); color: var(--ink); }
.price-btn-purple:hover { background: var(--purple-l); box-shadow: 0 8px 24px rgba(154,136,253,.4); }

.pricing-note {
  text-align: center; font-size: 13px; color: var(--ink-60);
  margin-top: 8px;
}
.pricing-note a { color: var(--purple); text-decoration: none; font-weight: 600; }
.pricing-note a:hover { text-decoration: underline; }
.pricing-note a:focus-visible {
  outline: 2px solid var(--purple);
  outline-offset: 2px;
  border-radius: 4px;
}

@media (max-width: 880px) {
  .pricing-grid {
    grid-template-columns: 1fr;
    max-width: 400px;
    margin-left: auto;
    margin-right: auto;
  }
  .pricing-toggle { width: 100%; }
  .ptoggle-btn { flex: 1; justify-content: center; }
}

@media (prefers-reduced-motion: reduce) {
  .hero h1 .line-inner { transform: none !important; animation: none !important; }
  .insp-card, .hero-right, .hero-tag, .ic-pin, .trip-card { animation: none !important; opacity: 1 !important; }
  .pros-stars::before, .pros-stars::after { animation: none !important; opacity: .45 !important; }
  .pricing-toggle-glider,
  .billing-pill-glider,
  .price-card {
    transition: none !important;
    animation: none !important;
  }
  .price-card:hover {
    transform: none;
    box-shadow: none;
  }
}

/* ══ CTA FINAL ══ */
.cta-band {
  background: #0A0818;
  padding: 0;
  position: relative;
  overflow: hidden;
  min-height: 560px;
  display: flex; align-items: stretch;
}

/* Pont haut pricing→dark */
.cta-band-top {
  position: absolute;
  top: -56px; left: 0; right: 0; height: 56px;
  background: linear-gradient(to bottom, transparent, #0A0818);
  pointer-events: none; z-index: 5;
}

/* Fond profond : layers de lumière */
.cta-band::before {
  content: '';
  position: absolute; inset: 0;
  background:
    radial-gradient(ellipse 70% 80% at -5% 50%, rgba(154,136,253,.22) 0%, transparent 55%),
    radial-gradient(ellipse 50% 60% at 105% 40%, rgba(202,254,135,.08) 0%, transparent 50%),
    radial-gradient(ellipse 40% 40% at 50% 110%, rgba(154,136,253,.12) 0%, transparent 50%),
    radial-gradient(ellipse 30% 30% at 80% 10%, rgba(254,222,128,.06) 0%, transparent 45%);
  pointer-events: none;
}

/* Grain texture overlay */
.cta-band::after {
  content: '';
  position: absolute; inset: 0;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
  background-size: 200px 200px;
  opacity: .6;
  pointer-events: none;
  mix-blend-mode: overlay;
}

/* Ghost document en fond — rappel du produit */
.cta-ghost-doc {
  position: absolute;
  right: -60px; top: 50%;
  transform: translateY(-50%) rotate(8deg);
  width: 320px;
  background: rgba(255,255,255,.03);
  border: 1px solid rgba(255,255,255,.06);
  border-radius: 24px;
  padding: 24px;
  pointer-events: none;
  z-index: 1;
}
.cta-ghost-header {
  display: flex; align-items: center; justify-content: space-between;
  padding-bottom: 14px;
  border-bottom: 2px solid rgba(154,136,253,.2);
  margin-bottom: 16px;
}
.cta-ghost-logo {
  width: 28px; height: 28px; border-radius: 6px;
  background: rgba(154,136,253,.15);
}
.cta-ghost-title {
  font-size: 9px; font-weight: 800;
  text-transform: uppercase; letter-spacing: 2px;
  color: rgba(154,136,253,.4);
}
.cta-ghost-line {
  height: 5px; background: rgba(255,255,255,.05);
  border-radius: 3px; margin-bottom: 7px;
}
.cta-ghost-line.w70 { width: 70%; }
.cta-ghost-line.w50 { width: 50%; }
.cta-ghost-line.w85 { width: 85%; }
.cta-ghost-rooms {
  display: grid; grid-template-columns: 1fr 1fr; gap: 6px;
  margin: 14px 0;
}
.cta-ghost-room {
  height: 36px; border-radius: 8px;
  background: rgba(255,255,255,.04);
  border: 1px solid rgba(255,255,255,.06);
}
.cta-ghost-sig {
  display: flex; gap: 10px; margin-top: 14px;
  padding-top: 14px;
  border-top: 1px solid rgba(255,255,255,.06);
}
.cta-ghost-sig-block { flex: 1; }
.cta-ghost-sig-line {
  height: 1px; background: rgba(255,255,255,.08);
  margin-bottom: 5px;
}
.cta-ghost-sig-lbl {
  font-size: 7px; text-transform: uppercase;
  letter-spacing: 1.5px; color: rgba(255,255,255,.15);
}

/* Layout asymétrique */
.cta-inner {
  position: relative; z-index: 3;
  width: 100%;
  max-width: 1360px; margin: 0 auto;
  padding: 100px 48px;
  display: grid;
  grid-template-columns: 1.1fr 1fr;
  gap: 80px;
  align-items: center;
}

/* Côté gauche : headline massive */
.cta-left {}

.cta-eyebrow {
  display: inline-flex; align-items: center; gap: 8px;
  font-size: 10px; text-transform: uppercase; letter-spacing: 3.5px;
  font-weight: 600; color: rgba(255,255,255,.3);
  margin-bottom: 28px;
}
.cta-eyebrow-dot {
  width: 5px; height: 5px; border-radius: 50%;
  background: var(--green); animation: eyePulse 2s infinite;
}

/* Headline dramatique — full scale */
.cta-inner h2 {
  font-family: 'Poppins', sans-serif;
  font-weight: 800;
  font-size: clamp(48px, 5.5vw, 80px);
  line-height: .95;
  letter-spacing: -4px;
  color: var(--white);
  margin-bottom: 32px;
}
.cta-inner h2 em {
  font-style: italic;
  color: transparent;
  -webkit-text-stroke: 1.5px var(--purple-l);
}

/* AED chiffre inline dans la headline */
.cta-aed {
  display: inline-block;
  color: var(--jasmine);
  -webkit-text-stroke: 0;
}

.cta-sub {
  font-size: 16px;
  color: rgba(255,255,255,.4);
  line-height: 1.75;
  max-width: 420px;
}

/* Stay informed — email capture */
.stay-informed {
  margin-top: 28px;
  max-width: 420px;
}
.stay-informed-label {
  font-size: 11px;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 2px;
  color: rgba(255,255,255,.35);
  margin: 0 0 12px;
}
.stay-informed-row {
  display: flex;
  gap: 8px;
  align-items: stretch;
}
.stay-informed-input {
  flex: 1;
  min-width: 0;
  padding: 13px 16px;
  border-radius: 12px;
  border: 1px solid rgba(255,255,255,.12);
  background: rgba(255,255,255,.06);
  color: var(--white);
  font-family: 'DM Sans', sans-serif;
  font-size: 14px;
  outline: none;
  transition: border-color .2s, background .2s;
}
.stay-informed-input::placeholder { color: rgba(255,255,255,.35); }
.stay-informed-input:focus {
  border-color: rgba(154,136,253,.55);
  background: rgba(255,255,255,.09);
}
.stay-informed-btn {
  flex-shrink: 0;
  padding: 13px 18px;
  border-radius: 12px;
  border: none;
  cursor: pointer;
  background: var(--purple);
  color: var(--ink);
  font-family: 'DM Sans', sans-serif;
  font-size: 13px;
  font-weight: 700;
  transition: transform .2s, box-shadow .2s, opacity .2s;
}
.stay-informed-btn:hover:not(:disabled) {
  transform: translateY(-2px);
  box-shadow: 0 8px 20px rgba(154,136,253,.35);
}
.stay-informed-btn:disabled { opacity: .6; cursor: wait; }
.stay-informed-msg {
  margin: 10px 0 0;
  font-size: 13px;
  line-height: 1.4;
  min-height: 1.2em;
}

/* Côté droit : CTA stack + sceau */
.cta-right {
  display: flex; flex-direction: column; gap: 16px;
}

/* Primary CTA — avec halo pulsé */
.cta-primary-wrap {
  position: relative;
  display: flex; justify-content: flex-start;
}
.cta-pulse-ring {
  position: absolute;
  top: 50%; left: 0;
  transform: translateY(-50%);
  width: 100%; height: 100%;
  border-radius: 999px;
  border: 1.5px solid rgba(154,136,253,.4);
  animation: ctaPulse 2.5s ease-out infinite;
  pointer-events: none;
}
@keyframes ctaPulse {
  0%   { transform: translateY(-50%) scale(1);   opacity: .6; }
  70%  { transform: translateY(-50%) scale(1.08); opacity: 0; }
  100% { transform: translateY(-50%) scale(1.08); opacity: 0; }
}
.btn-cta-primary {
  display: inline-flex; align-items: center; gap: 10px;
  padding: 17px 32px;
  background: var(--purple);
  color: var(--ink);
  font-family: 'Poppins', sans-serif;
  font-weight: 800; font-size: 15px;
  border-radius: 999px; text-decoration: none;
  border: none; cursor: pointer;
  transition: background .3s, transform .35s cubic-bezier(.16,1,.3,1), box-shadow .35s;
  position: relative; z-index: 1;
  width: 100%; justify-content: center;
}
.btn-cta-primary:hover {
  background: #B4A4FE;
  transform: translateY(-4px);
  box-shadow: 0 20px 48px rgba(154,136,253,.45);
}

.cta-divider-row {
  display: flex; align-items: center; gap: 12px;
}
.cta-divider-row::before,
.cta-divider-row::after {
  content: '';
  flex: 1; height: 1px;
  background: rgba(255,255,255,.08);
}
.cta-divider-row span {
  font-size: 11px; color: rgba(255,255,255,.2);
  font-weight: 600; white-space: nowrap;
}

.btn-cta-ghost {
  display: inline-flex; align-items: center; gap: 10px;
  padding: 15px 28px;
  background: rgba(255,255,255,.05);
  color: rgba(255,255,255,.7);
  font-family: 'Poppins', sans-serif;
  font-weight: 600; font-size: 14px;
  border-radius: 999px; text-decoration: none;
  border: 1.5px solid rgba(255,255,255,.1);
  transition: background .3s, border-color .3s, transform .3s;
  cursor: pointer;
  justify-content: center;
}
.btn-cta-ghost:hover {
  background: rgba(255,255,255,.1);
  border-color: rgba(255,255,255,.2);
  transform: translateY(-3px);
}

/* Sceau de confiance */
.cta-seal {
  margin-top: 8px;
  padding: 18px 20px;
  background: rgba(255,255,255,.04);
  border: 1px solid rgba(255,255,255,.08);
  border-radius: 16px;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px;
}
.cta-seal-item {
  display: flex; align-items: center; gap: 9px;
}
.cta-seal-icon {
  width: 28px; height: 28px; border-radius: 8px;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.cta-seal-icon svg { width: 13px; height: 13px; }
.si-green { background: rgba(202,254,135,.12); color: var(--green); }
.si-purple { background: rgba(154,136,253,.12); color: var(--purple-l); }
.si-jasmine { background: rgba(254,222,128,.1); color: var(--jasmine); }
.si-white { background: rgba(255,255,255,.07); color: rgba(255,255,255,.5); }
.cta-seal-text {}
.cta-seal-title {
  font-size: 12px; font-weight: 700;
  color: rgba(255,255,255,.7); line-height: 1.2;
}
.cta-seal-sub {
  font-size: 10px; color: rgba(255,255,255,.3);
}

@media(max-width: 1100px) {
  .cta-inner {
    grid-template-columns: 1fr;
    gap: 48px; padding: 80px 48px;
  }
  .cta-ghost-doc { display: none; }
}
@media(max-width: 768px) {
  .cta-inner { padding: 72px 20px; }
  .cta-inner h2 { font-size: clamp(42px, 9vw, 64px); letter-spacing: -2.5px; line-height: 1.0; }
}


/* ══ FOOTER ══ */
footer {
  background: var(--ink);
  padding: 80px 48px 40px;
  color: rgba(255,255,255,.55);
}
.footer-top {
  display: grid;
  grid-template-columns: 2fr 1fr 1fr;
  gap: 60px; margin-bottom: 56px;
}
.foot-brand {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}
.foot-brand p {
  font-size: 14px; line-height: 1.75;
  margin-top: 14px; max-width: 300px;
  color: rgba(255,255,255,.45);
}
.foot-badge {
  display: inline-flex; align-items: center; gap: 7px;
  margin-top: 16px;
  font-size: 11px; font-weight: 600;
  text-transform: uppercase; letter-spacing: 2px;
  color: rgba(255,255,255,.65);
}
.foot-badge svg { opacity: .75; }
.foot-col h4 {
  font-family: 'Poppins', sans-serif;
  font-weight: 700; font-size: 13px;
  color: var(--white); margin-bottom: 18px;
  text-transform: uppercase; letter-spacing: 1.5px;
}
.foot-col ul {
  list-style: none;
  display: flex; flex-direction: column; gap: 10px;
}
.foot-col a {
  color: rgba(255,255,255,.6); text-decoration: none;
  font-size: 14px; transition: color .25s;
}
.foot-col a:hover { color: var(--purple); }
.footer-bottom {
  display: flex; align-items: center; justify-content: space-between;
  padding-top: 28px;
  border-top: 1px solid rgba(255,255,255,.06);
}
.footer-bottom p { font-size: 13px; color: rgba(255,255,255,.6); }
.foot-socials { display: flex; gap: 8px; align-items: center; flex-wrap: wrap; }
.foot-socials a {
  width: 40px; height: 40px; border-radius: 10px;
  background: rgba(255,255,255,.05);
  border: 1px solid rgba(255,255,255,.07);
  display: flex; align-items: center; justify-content: center;
  color: rgba(255,255,255,.4); text-decoration: none;
  transition: all .25s;
}
.foot-socials a:hover {
  background: var(--purple); color: var(--ink);
  border-color: var(--purple);
}
.foot-chat-btn {
  display: inline-flex; align-items: center; gap: 8px;
  padding: 10px 16px; border-radius: 999px; border: none; cursor: pointer;
  background: var(--purple); color: var(--ink);
  font-family: 'DM Sans', sans-serif; font-size: 13px; font-weight: 600;
  transition: transform .2s, box-shadow .2s;
}
.foot-chat-btn:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 20px rgba(154,136,253,.35);
}
.foot-ph {
