---
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';

const canonicalUrl = 'https://snagify.net/ar/';
const altEn = 'https://snagify.net/';
const altAr = 'https://snagify.net/ar/';
---
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Snagify · فحوصات العقارات الرقمية في دبي · معتمدة لدى RDC</title>
<meta name="description" content="فحوصات العقارات الرقمية لسوق الإيجار في دبي. مدعومة بالذكاء الاصطناعي، معتمدة لدى مركز فضّ المنازعات الإيجارية، ومصمّمة للمحترفين والملاك على حدّ سواء.">
<meta name="keywords" content="فحص العقارات دبي, فحص الإيجار دبي, تطبيق RDC دبي, فحص الانتقال دبي, فحص الخروج دبي, إيجاري دبي">
<link rel="canonical" href={canonicalUrl}>
<link rel="alternate" hreflang="en" href={altEn}>
<link rel="alternate" hreflang="ar" href={altAr}>
<link rel="alternate" hreflang="x-default" href={altEn}>
<meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1">
<meta name="author" content="Snagify · MULKEEF">
<meta http-equiv="content-language" content="ar-AE">

<meta property="og:type" content="website">
<meta property="og:title" content="Snagify · فحوصات العقارات الرقمية في دبي">
<meta property="og:description" content="فحوصات العقارات الرقمية لسوق الإيجار في دبي. مدعومة بالذكاء الاصطناعي، معتمدة لدى RDC.">
<meta property="og:url" content={canonicalUrl}>
<meta property="og:image" content="https://snagify.net/og-image.png">
<meta property="og:site_name" content="Snagify">
<meta property="og:locale" content="ar_AE">
<meta property="og:locale:alternate" content="en_AE">

<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="Snagify · فحوصات العقارات الرقمية في دبي">
<meta name="twitter:description" content="فحوصات العقارات الرقمية لسوق الإيجار في دبي. مدعومة بالذكاء الاصطناعي، معتمدة لدى RDC.">
<meta name="twitter:image" content="https://snagify.net/og-image.png">

<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
<link rel="icon" href="/favicon.ico">

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Noto+Naskh+Arabic:wght@400;500;600;700&family=Tajawal:wght@400;500;700;800&family=Poppins:ital,wght@0,400;0,500;0,700;0,800;1,700;1,800&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300;1,9..40,400&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">

<link rel="stylesheet" href="/src/styles/rtl.css">

<style>
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
* { cursor: auto; }
a, button, [role="button"] { cursor: pointer; }
input, textarea, select { cursor: text; }

:root {
  --cream: #F3F1EB;
  --paper: #FCFCFC;
  --ink: #0E0E10;
  --ink-70: rgba(14,14,16,0.7);
  --ink-60: rgba(14,14,16,0.6);
  --ink-25: rgba(14,14,16,0.12);
  --ink-10: rgba(14,14,16,0.08);
  --ink-05: rgba(14,14,16,0.04);
  --purple: #9A88FD;
  --purple-bg: rgba(154,136,253,0.1);
  --jasmine: #FEDE80;
  --green: #CAFE87;
  --white: #FCFCFC;
}
html { scroll-behavior: smooth; }
body {
  font-family: 'Noto Naskh Arabic', 'Tajawal', system-ui, sans-serif;
  background: var(--cream);
  color: var(--ink);
  line-height: 1.85;
  -webkit-font-smoothing: antialiased;
  text-align: right;
  direction: rtl;
}
.container { max-width: 1080px; margin: 0 auto; padding: 0 32px; }

.hero { padding: 96px 0 80px; }
.hero-eyebrow {
  display: inline-flex; align-items: center; gap: 8px;
  padding: 6px 14px; border-radius: 999px; background: var(--ink-05);
  font-size: 12px; font-weight: 600; color: var(--ink-70);
  letter-spacing: 0.5px; margin-bottom: 22px;
  font-family: 'JetBrains Mono', monospace;
}
.hero-eyebrow-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--purple); }

.hero h1 {
  font-family: 'Tajawal', sans-serif; font-weight: 800;
  font-size: clamp(40px, 6vw, 72px); line-height: 1.1;
  letter-spacing: -1.6px; max-width: 880px; margin-bottom: 24px;
}
.hero h1 em { color: var(--purple); font-style: normal; }
.hero-sub {
  font-family: 'Noto Naskh Arabic', sans-serif;
  font-size: 20px; line-height: 1.7; color: var(--ink-70);
  max-width: 720px; margin-bottom: 36px;
}
.hero-actions { display: flex; gap: 14px; flex-wrap: wrap; }
.hero-cta {
  display: inline-flex; align-items: center; gap: 8px;
  padding: 16px 30px; background: var(--ink); color: var(--white);
  font-family: 'Tajawal', sans-serif; font-weight: 800; font-size: 15px;
  border-radius: 999px; text-decoration: none;
  transition: transform 0.25s, box-shadow 0.25s;
}
.hero-cta:hover { transform: translateY(-2px); box-shadow: 0 12px 30px rgba(14,14,16,0.25); }
.hero-cta-secondary {
  display: inline-flex; align-items: center; gap: 8px;
  padding: 16px 30px; background: transparent; color: var(--ink);
  font-family: 'Tajawal', sans-serif; font-weight: 700; font-size: 15px;
  border-radius: 999px; text-decoration: none;
  border: 1px solid var(--ink-25);
  transition: border-color 0.25s, background 0.25s;
}
.hero-cta-secondary:hover { border-color: var(--ink); background: var(--ink-05); }

.section { padding: 72px 0; }
.section-eyebrow {
  font-family: 'JetBrains Mono', monospace; font-size: 11px;
  text-transform: uppercase; letter-spacing: 0.6px;
  color: var(--purple); margin-bottom: 14px;
}
.section h2 {
  font-family: 'Tajawal', sans-serif; font-weight: 800;
  font-size: clamp(30px, 4.5vw, 48px); line-height: 1.15;
  letter-spacing: -1px; max-width: 800px; margin-bottom: 22px;
}
.section-sub {
  font-size: 18px; line-height: 1.7; color: var(--ink-70);
  max-width: 720px; margin-bottom: 48px;
}

.grid-3 {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 18px;
}
@media (max-width: 860px) { .grid-3 { grid-template-columns: 1fr; } }

.card {
  background: var(--paper);
  border: 1px solid var(--ink-10);
  border-radius: 18px; padding: 30px;
}
.card-tick {
  display: inline-flex; align-items: center; justify-content: center;
  width: 36px; height: 36px; border-radius: 10px;
  background: var(--purple-bg); color: var(--purple);
  margin-bottom: 18px;
}
.card-tick svg { width: 20px; height: 20px; stroke-width: 2.5; stroke: var(--purple); fill: none; stroke-linecap: round; stroke-linejoin: round; }
.card h3 {
  font-family: 'Tajawal', sans-serif; font-weight: 700;
  font-size: 19px; line-height: 1.3; margin-bottom: 12px;
}
.card p { font-size: 15px; line-height: 1.7; color: var(--ink-70); }

.trust-row {
  display: grid; grid-template-columns: repeat(4, 1fr); gap: 18px;
}
@media (max-width: 720px) { .trust-row { grid-template-columns: repeat(2, 1fr); } }
.trust-item {
  background: var(--paper); border: 1px solid var(--ink-10);
  border-radius: 14px; padding: 20px; text-align: center;
}
.trust-item-num {
  font-family: 'Tajawal', sans-serif; font-weight: 800;
  font-size: 32px; color: var(--purple); margin-bottom: 6px;
  direction: ltr;
}
.trust-item-label {
  font-size: 13px; color: var(--ink-70); line-height: 1.5;
}

.final-cta {
  background: var(--ink); color: var(--white);
  border-radius: 32px;
  padding: 80px 48px; text-align: center;
  position: relative; overflow: hidden;
  margin: 24px 0 80px;
}
.final-cta::before {
  content: ''; position: absolute;
  top: -100px; left: -100px;
  width: 360px; height: 360px; border-radius: 50%;
  background: rgba(154,136,253,0.18); filter: blur(80px); pointer-events: none;
}
.final-cta h2 {
  font-family: 'Tajawal', sans-serif; font-weight: 800;
  font-size: clamp(32px, 4.5vw, 52px); line-height: 1.1;
  letter-spacing: -1.2px; margin-bottom: 18px;
  position: relative; color: var(--white);
}
.final-cta p {
  font-size: 18px; color: rgba(252,252,252,0.7);
  margin-bottom: 32px; position: relative;
  max-width: 540px; margin-right: auto; margin-left: auto;
}
.final-cta-btn {
  display: inline-flex; align-items: center; gap: 8px;
  padding: 18px 36px;
  background: var(--purple); color: var(--ink);
  font-family: 'Tajawal', sans-serif; font-weight: 800; font-size: 16px;
  border-radius: 999px; text-decoration: none;
  position: relative;
  transition: transform 0.25s, box-shadow 0.25s;
}
.final-cta-btn:hover { transform: translateY(-2px); box-shadow: 0 14px 36px rgba(154,136,253,0.35); }

@media (max-width: 720px) {
  .container { padding: 0 18px; }
  .hero { padding: 64px 0 56px; }
  .section { padding: 56px 0; }
  .final-cta { padding: 56px 24px; }
}
</style>
</head>
<body>

<SiteHeader />

<main>

<section class="hero container">
  <div class="hero-eyebrow"><span class="hero-eyebrow-dot"></span>SNAGIFY · DUBAI</div>
  <h1>فحوصات عقارية تصمد في <em>RDC</em>.</h1>
  <p class="hero-sub">يحوّل Snagify كل عملية فحص إلى دليل قابل للدفاع: تحليل ذكي للصور، توقيعات رقمية مزدوجة، تحقق تشفيري بـ SHA-256. مجاني عند الاستلام.</p>
  <div class="hero-actions">
    <a href="https://app.snagify.net" class="hero-cta">جرّب Snagify مجانًا ←</a>
    <a href="/sample-report.pdf" target="_blank" class="hero-cta-secondary">شاهد تقريرًا نموذجيًا</a>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="trust-row">
      <div class="trust-item">
        <div class="trust-item-num">40+</div>
        <div class="trust-item-label">وكالة في دبي تستخدمنا</div>
      </div>
      <div class="trust-item">
        <div class="trust-item-num">15K+</div>
        <div class="trust-item-label">فحص أُجري</div>
      </div>
      <div class="trust-item">
        <div class="trust-item-num">80%</div>
        <div class="trust-item-label">تأمينات استُرجعت</div>
      </div>
      <div class="trust-item">
        <div class="trust-item-num">20 min</div>
        <div class="trust-item-label">متوسط مدة الفحص</div>
      </div>
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="section-eyebrow">المنتج</div>
    <h2>كل ما تحتاجه لربح كل نزاع.</h2>
    <p class="section-sub">ثلاث ركائز تجعل Snagify مرجعًا في فحوصات العقارات في دبي.</p>
    <div class="grid-3">
      <div class="card">
        <div class="card-tick">
          <svg viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"/></svg>
        </div>
        <h3>ذكاء اصطناعي يلتقط ما تفوّته</h3>
        <p>يصنّف Claude AI كل الأضرار في صورك تلقائيًا: تشقّقات الجدران، تآكل الطلاء، شظايا البلاط. لن تنسى ما لم تره.</p>
      </div>
      <div class="card">
        <div class="card-tick">
          <svg viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"/></svg>
        </div>
        <h3>أدلة معتمدة لدى RDC</h3>
        <p>كل تقرير يصدر مع أختام زمنية، توقيعات مزدوجة، بيانات وصفية للصور، وبصمة تشفيرية SHA-256. يقبله RDC كما هو.</p>
      </div>
      <div class="card">
        <div class="card-tick">
          <svg viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"/></svg>
        </div>
        <h3>20 دقيقة من البداية للنهاية</h3>
        <p>تدفّق إرشادي محسَّن غرفة بغرفة. اكتشاف إيجاري التلقائي، صور موسومة، توقيع رقمي. تقرير PDF احترافي في 60 ثانية.</p>
      </div>
    </div>
  </div>
</section>

<section class="container">
  <div class="final-cta">
    <h2>أهلًا بك في فحوصات أحدث من 2010.</h2>
    <p>فحص استلام مجاني، بدون بطاقة ائتمان. اطّلع على ما يستخدمه أكثر من 40 وكالة في دبي.</p>
    <a href="https://app.snagify.net" class="final-cta-btn">ابدأ مجانًا الآن ←</a>
  </div>
</section>

</main>

<SiteFooter />

</body>
</html>
