---
import neighborhoodsDataRU from '../../../data/neighborhoods.ru.json';
import NeighborhoodLayout from '../../../layouts/NeighborhoodLayout.astro';

export async function getStaticPaths() {
  return Object.values(neighborhoodsDataRU).map(neighborhood => ({
    params: { slug: neighborhood.slug },
    props: { neighborhood }
  }));
}

const { neighborhood } = Astro.props;
---
<NeighborhoodLayout neighborhood={neighborhood} locale="ru" />
