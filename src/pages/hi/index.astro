---
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';

const canonicalUrl = 'https://snagify.net/hi/';
const altEn = 'https://snagify.net/';
const altAr = 'https://snagify.net/ar/';
const altRu = 'https://snagify.net/ru/';
const altHi = 'https://snagify.net/hi/';
---
<!DOCTYPE html>
<html lang="hi" dir="ltr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Snagify · दुबई में डिजिटल संपत्ति निरीक्षण · RDC में मान्य</title>
<meta name="description" content="दुबई के किराये के बाजार के लिए डिजिटल संपत्ति निरीक्षण। AI-संचालित, RDC में मान्य, और पेशेवरों तथा मकान मालिकों दोनों के लिए बनाया गया।">
<meta name="keywords" content="संपत्ति निरीक्षण दुबई, किराया निरीक्षण दुबई, RDC ऐप दुबई, चेक-इन निरीक्षण दुबई, चेक-आउट निरीक्षण दुबई, ejari दुबई">
<link rel="canonical" href={canonicalUrl}>
<link rel="alternate" hreflang="en" href={altEn}>
<link rel="alternate" hreflang="ar" href={altAr}>
<link rel="alternate" hreflang="ru" href={altRu}>
<link rel="alternate" hreflang="hi" href={altHi}>
<link rel="alternate" hreflang="x-default" href={altEn}>
<meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1">
<meta name="author" content="Snagify · MULKEEF">
<meta http-equiv="content-language" content="hi-AE">

<meta property="og:type" content="website">
<meta property="og:title" content="Snagify · दुबई में डिजिटल संपत्ति निरीक्षण">
<meta property="og:description" content="दुबई के किराये के बाजार के लिए डिजिटल संपत्ति निरीक्षण। AI-संचालित, RDC में मान्य।">
<meta property="og:url" content={canonicalUrl}>
<meta property="og:image" content="https://snagify.net/og-image.png">
<meta property="og:site_name" content="Snagify">
<meta property="og:locale" content="hi_AE">
<meta property="og:locale:alternate" content="en_AE">
<meta property="og:locale:alternate" content="ar_AE">
<meta property="og:locale:alternate" content="ru_AE">

<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="Snagify · दुबई में डिजिटल संपत्ति निरीक्षण">
<meta name="twitter:description" content="दुबई के किराये के बाजार के लिए डिजिटल संपत्ति निरीक्षण।">
<meta name="twitter:image" content="https://snagify.net/og-image.png">

<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
<link rel="icon" href="/favicon.ico">

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+Devanagari:wght@400;500;600;700;800&family=Poppins:ital,wght@0,400;0,500;0,700;0,800;1,700;1,800&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300;1,9..40,400&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">

<style>
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
* { cursor: auto; }
a, button, [role="button"] { cursor: pointer; }
input, textarea, select { cursor: text; }

:root {
  --cream: #F3F1EB;
  --paper: #FCFCFC;
  --ink: #0E0E10;
  --ink-70: rgba(14,14,16,0.7);
  --ink-60: rgba(14,14,16,0.6);
  --ink-25: rgba(14,14,16,0.12);
  --ink-10: rgba(14,14,16,0.08);
  --ink-05: rgba(14,14,16,0.04);
  --purple: #9A88FD;
  --purple-bg: rgba(154,136,253,0.1);
  --jasmine: #FEDE80;
  --green: #CAFE87;
  --white: #FCFCFC;
}
html { scroll-behavior: smooth; }
body {
  font-family: 'Noto Sans Devanagari', 'DM Sans', system-ui, sans-serif;
  background: var(--cream); color: var(--ink); line-height: 1.75;
  -webkit-font-smoothing: antialiased;
}
.container { max-width: 1080px; margin: 0 auto; padding: 0 32px; }

.hero { padding: 96px 0 80px; }
.hero-eyebrow {
  display: inline-flex; align-items: center; gap: 8px;
  padding: 6px 14px; border-radius: 999px; background: var(--ink-05);
  font-size: 12px; font-weight: 600; color: var(--ink-70);
  letter-spacing: 0.5px; margin-bottom: 22px;
  font-family: 'JetBrains Mono', monospace;
}
.hero-eyebrow-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--purple); }

.hero h1 {
  font-family: 'Noto Sans Devanagari', sans-serif; font-weight: 800;
  font-size: clamp(34px, 5vw, 60px); line-height: 1.15;
  letter-spacing: -0.8px; max-width: 880px; margin-bottom: 24px;
}
.hero h1 em { color: var(--purple); font-style: normal; }
.hero-sub {
  font-size: 18px; line-height: 1.75; color: var(--ink-70);
  max-width: 720px; margin-bottom: 36px;
}
.hero-actions { display: flex; gap: 14px; flex-wrap: wrap; }
.hero-cta {
  display: inline-flex; align-items: center; gap: 8px;
  padding: 16px 30px; background: var(--ink); color: var(--white);
  font-family: 'Noto Sans Devanagari', sans-serif; font-weight: 700; font-size: 15px;
  border-radius: 999px; text-decoration: none;
  transition: transform 0.25s, box-shadow 0.25s;
}
.hero-cta:hover { transform: translateY(-2px); box-shadow: 0 12px 30px rgba(14,14,16,0.25); }
.hero-cta-secondary {
  display: inline-flex; align-items: center; gap: 8px;
  padding: 16px 30px; background: transparent; color: var(--ink);
  font-family: 'Noto Sans Devanagari', sans-serif; font-weight: 600; font-size: 15px;
  border-radius: 999px; text-decoration: none;
  border: 1px solid var(--ink-25);
  transition: border-color 0.25s, background 0.25s;
}
.hero-cta-secondary:hover { border-color: var(--ink); background: var(--ink-05); }

.section { padding: 72px 0; }
.section-eyebrow {
  font-family: 'JetBrains Mono', monospace; font-size: 11px;
  text-transform: uppercase; letter-spacing: 0.6px;
  color: var(--purple); margin-bottom: 14px;
}
.section h2 {
  font-family: 'Noto Sans Devanagari', sans-serif; font-weight: 800;
  font-size: clamp(26px, 4vw, 40px); line-height: 1.2;
  letter-spacing: -0.6px; max-width: 800px; margin-bottom: 22px;
}
.section-sub {
  font-size: 17px; line-height: 1.7; color: var(--ink-70);
  max-width: 720px; margin-bottom: 48px;
}

.grid-3 {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 18px;
}
@media (max-width: 860px) { .grid-3 { grid-template-columns: 1fr; } }

.card {
  background: var(--paper);
  border: 1px solid var(--ink-10);
  border-radius: 18px; padding: 30px;
}
.card-tick {
  display: inline-flex; align-items: center; justify-content: center;
  width: 36px; height: 36px; border-radius: 10px;
  background: var(--purple-bg); color: var(--purple);
  margin-bottom: 18px;
}
.card-tick svg { width: 20px; height: 20px; stroke-width: 2.5; stroke: var(--purple); fill: none; stroke-linecap: round; stroke-linejoin: round; }
.card h3 {
  font-family: 'Noto Sans Devanagari', sans-serif; font-weight: 700;
  font-size: 18px; line-height: 1.4; margin-bottom: 12px;
}
.card p { font-size: 15px; line-height: 1.75; color: var(--ink-70); }

.trust-row {
  display: grid; grid-template-columns: repeat(4, 1fr); gap: 18px;
}
@media (max-width: 720px) { .trust-row { grid-template-columns: repeat(2, 1fr); } }
.trust-item {
  background: var(--paper); border: 1px solid var(--ink-10);
  border-radius: 14px; padding: 20px; text-align: center;
}
.trust-item-num {
  font-family: 'Poppins', sans-serif; font-weight: 800;
  font-size: 32px; color: var(--purple); margin-bottom: 6px;
}
.trust-item-label {
  font-size: 13px; color: var(--ink-70); line-height: 1.6;
}

.final-cta {
  background: var(--ink); color: var(--white);
  border-radius: 32px;
  padding: 80px 48px; text-align: center;
  position: relative; overflow: hidden;
  margin: 24px 0 80px;
}
.final-cta::before {
  content: ''; position: absolute;
  top: -100px; right: -100px;
  width: 360px; height: 360px; border-radius: 50%;
  background: rgba(154,136,253,0.18); filter: blur(80px); pointer-events: none;
}
.final-cta h2 {
  font-family: 'Noto Sans Devanagari', sans-serif; font-weight: 800;
  font-size: clamp(28px, 4vw, 42px); line-height: 1.2;
  letter-spacing: -0.6px; margin-bottom: 18px;
  position: relative; color: var(--white);
}
.final-cta p {
  font-size: 17px; color: rgba(252,252,252,0.7);
  margin-bottom: 32px; position: relative;
  max-width: 540px; margin: 0 auto 32px;
}
.final-cta-btn {
  display: inline-flex; align-items: center; gap: 8px;
  padding: 18px 36px;
  background: var(--purple); color: var(--ink);
  font-family: 'Noto Sans Devanagari', sans-serif; font-weight: 700; font-size: 16px;
  border-radius: 999px; text-decoration: none;
  position: relative;
  transition: transform 0.25s, box-shadow 0.25s;
}
.final-cta-btn:hover { transform: translateY(-2px); box-shadow: 0 14px 36px rgba(154,136,253,0.35); }

@media (max-width: 720px) {
  .container { padding: 0 18px; }
  .hero { padding: 64px 0 56px; }
  .section { padding: 56px 0; }
  .final-cta { padding: 56px 24px; }
}
</style>
</head>
<body>

<SiteHeader />

<main>

<section class="hero container">
  <div class="hero-eyebrow"><span class="hero-eyebrow-dot"></span>SNAGIFY · DUBAI</div>
  <h1>संपत्ति निरीक्षण जो <em>RDC में टिकते हैं</em>।</h1>
  <p class="hero-sub">Snagify हर निरीक्षण को बचाव योग्य प्रमाण में बदलता है: AI तस्वीर विश्लेषण, दोहरे डिजिटल हस्ताक्षर, SHA-256 क्रिप्टोग्राफिक सत्यापन। चेक-इन पर मुफ़्त।</p>
  <div class="hero-actions">
    <a href="https://app.snagify.net" class="hero-cta">Snagify मुफ़्त में आज़माएँ →</a>
    <a href="/sample-report.pdf" target="_blank" class="hero-cta-secondary">नमूना रिपोर्ट देखें</a>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="trust-row">
      <div class="trust-item">
        <div class="trust-item-num">40+</div>
        <div class="trust-item-label">दुबई की एजेंसियाँ हमारा उपयोग करती हैं</div>
      </div>
      <div class="trust-item">
        <div class="trust-item-num">15K+</div>
        <div class="trust-item-label">किए गए निरीक्षण</div>
      </div>
      <div class="trust-item">
        <div class="trust-item-num">80%</div>
        <div class="trust-item-label">वापस की गई जमानत राशि</div>
      </div>
      <div class="trust-item">
        <div class="trust-item-num">20 min</div>
        <div class="trust-item-label">औसत निरीक्षण समय</div>
      </div>
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="section-eyebrow">उत्पाद</div>
    <h2>हर विवाद जीतने के लिए वो सब कुछ जो आपको चाहिए।</h2>
    <p class="section-sub">तीन स्तंभ जो Snagify को दुबई में संपत्ति निरीक्षण का संदर्भ बनाते हैं।</p>
    <div class="grid-3">
      <div class="card">
        <div class="card-tick">
          <svg viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"/></svg>
        </div>
        <h3>AI वो पकड़ता है जो आप चूक जाते हैं</h3>
        <p>Claude AI आपकी तस्वीरों में सभी क्षति को स्वचालित रूप से वर्गीकृत करता है: दीवार की दरारें, पेंट का घिसाव, टाइल चिप्स। आप वो नहीं भूल सकते जो आपने नहीं देखा।</p>
      </div>
      <div class="card">
        <div class="card-tick">
          <svg viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"/></svg>
        </div>
        <h3>RDC में मान्य प्रमाण</h3>
        <p>हर रिपोर्ट समय की मुहर, दोहरे हस्ताक्षर, तस्वीर मेटाडेटा और SHA-256 क्रिप्टोग्राफिक हैश के साथ आती है। RDC इसे जैसा है वैसा स्वीकार करता है।</p>
      </div>
      <div class="card">
        <div class="card-tick">
          <svg viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"/></svg>
        </div>
        <h3>शुरू से अंत तक 20 मिनट</h3>
        <p>कमरा-दर-कमरा निर्देशित प्रक्रिया। Ejari का स्वतः पता लगाना, AI-टैग की गई तस्वीरें, डिजिटल हस्ताक्षर। 60 सेकंड में पेशेवर PDF रिपोर्ट।</p>
      </div>
    </div>
  </div>
</section>

<section class="container">
  <div class="final-cta">
    <h2>2010 से नए निरीक्षणों में आपका स्वागत है।</h2>
    <p>मुफ़्त चेक-इन निरीक्षण, बिना क्रेडिट कार्ड के। 40+ दुबई एजेंसियाँ क्या उपयोग करती हैं देखें।</p>
    <a href="https://app.snagify.net" class="final-cta-btn">अभी मुफ़्त में शुरू करें →</a>
  </div>
</section>

</main>

<SiteFooter />

</body>
</html>
