<style>
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
:root {
  --cream: #F3F1EB; --cream-2: #EAE8E0; --white: #FCFCFC;
  --ink: #0E0E10; --ink-60: rgba(14,14,16,0.6); --ink-25: rgba(14,14,16,0.1);
  --purple: #9A88FD; --purple-bg: #EDE9FE; --jasmine: #FEDE80; --jasmine-bg: #FFF8DC;
}
html { scroll-behavior: smooth; }
body { font-family: 'DM Sans', sans-serif; background: var(--white); color: var(--ink); -webkit-font-smoothing: antialiased; }

nav {
  position: sticky; top: 0; z-index: 100;
  display: flex; align-items: center; justify-content: space-between;
  padding: 20px 48px;
  background: rgba(252,252,252,.92); backdrop-filter: blur(16px);
  border-bottom: 1px solid var(--ink-25);
}
.nav-logo { display:flex;align-items:center;gap:9px;text-decoration:none; }
.nav-logo span { font-family:'Poppins',sans-serif;font-weight:800;font-size:20px;color:var(--ink); }
.nav-back { display:inline-flex;align-items:center;gap:7px;font-size:14px;font-weight:600;color:var(--ink-60);text-decoration:none;transition:color .2s; }
.nav-back:hover { color:var(--ink); }
.nav-back:hover svg { transform:translateX(-3px); }
.nav-back svg { transition:transform .2s; }

.page-hero { padding:80px 48px 60px; max-width:800px; margin:0 auto; border-bottom:1px solid var(--ink-25); }
.page-eyebrow { display:inline-flex;align-items:center;gap:8px;font-size:11px;text-transform:uppercase;letter-spacing:3px;font-weight:600;color:var(--ink-60);margin-bottom:20px; }
.page-eyebrow::before { content:'';width:16px;height:1.5px;background:var(--ink-60); }
.page-hero h1 { font-family:'Poppins',sans-serif;font-weight:800;font-size:clamp(36px,4vw,52px);letter-spacing:-2px;margin-bottom:12px; }
.page-meta { font-size:14px;color:var(--ink-60);display:flex;align-items:center;gap:16px;flex-wrap:wrap; }
.page-meta span { display:flex;align-items:center;gap:6px; }

.layout { display:grid;grid-template-columns:220px 1fr;gap:60px;max-width:1000px;margin:0 auto;padding:60px 48px 100px;align-items:start; }

.toc { position:sticky;top:88px; }
.toc-title { font-size:10px;text-transform:uppercase;letter-spacing:2.5px;font-weight:700;color:var(--ink-60);margin-bottom:16px; }
.toc-list { list-style:none;display:flex;flex-direction:column;gap:2px; }
.toc-list a { display:block;padding:8px 12px;border-radius:8px;font-size:13px;font-weight:500;color:var(--ink-60);text-decoration:none;transition:all .2s; }
.toc-list a:hover, .toc-list a.active { background:var(--purple-bg);color:var(--purple);font-weight:600; }

.content { min-width:0; }
.content-section { margin-bottom:56px; }
.content-section:last-child { margin-bottom:0; }
.content-section h2 { font-family:'Poppins',sans-serif;font-weight:800;font-size:22px;letter-spacing:-.5px;margin-bottom:16px;padding-bottom:12px;border-bottom:2px solid var(--purple-bg);scroll-margin-top:100px; }
.content-section p { font-size:15px;color:var(--ink-60);line-height:1.8;margin-bottom:14px; }
.content-section p:last-child { margin-bottom:0; }
.content-section ul { padding-left:0;list-style:none;display:flex;flex-direction:column;gap:8px;margin-bottom:14px; }
.content-section ul li { display:flex;align-items:flex-start;gap:10px;font-size:15px;color:var(--ink-60);line-height:1.7; }
.content-section ul li::before { content:'·';color:var(--purple);font-weight:800;flex-shrink:0;margin-top:1px; }
.content-section h3 { font-family:'Poppins',sans-serif;font-weight:700;font-size:16px;margin:20px 0 10px; }

.warning-box { padding:20px 24px;background:var(--jasmine-bg);border:1px solid rgba(254,222,128,.5);border-radius:14px;font-size:14px;color:#7A5A00;line-height:1.7;margin-bottom:14px;display:flex;align-items:flex-start;gap:10px; }
.warning-box svg { flex-shrink:0;margin-top:2px; }

.contact-box { padding:24px;background:var(--cream);border-radius:16px;border:1px solid var(--ink-25); }
.contact-box h3 { font-family:'Poppins',sans-serif;font-weight:700;font-size:16px;margin-bottom:8px; }
.contact-box p { font-size:14px;color:var(--ink-60);margin-bottom:0; }
.contact-box a { color:var(--purple);text-decoration:none;font-weight:600; }

footer { background:var(--ink);padding:40px 48px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px; }
.foot-copy { font-size:13px;color:rgba(255,255,255,.3); }
.foot-links { display:flex;gap:20px; }
.foot-links a { font-size:13px;color:rgba(255,255,255,.35);text-decoration:none;transition:color .2s; }
.foot-links a:hover { color:#9A88FD; }

@media(max-width:768px) {
  nav { padding:14px 20px; }
  .page-hero { padding:60px 20px 40px; }
  .layout { grid-template-columns:1fr;padding:40px 20px 60px;gap:40px; }
  .toc { position:static; }
  footer { padding:32px 20px;flex-direction:column; }
}
</style>
